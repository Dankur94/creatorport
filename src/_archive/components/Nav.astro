---
/**
 * Nav — Minimal app-like navigation.
 * Logo left, links + lang toggle + hamburger right.
 */
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const links = [
  { href: '/our-story', en: 'Our Story', de: 'Unsere Geschichte' },
  { href: '/team', en: 'Team', de: 'Team' },
  { href: '/checkout', en: 'Book Now', de: 'Buchen' },
];
---

<nav class="nav">
  <a href="/" class="nav-logo">
    <img src="/creatorport-logo.svg" alt="CreatorPort HK" />
  </a>

  <div class="nav-links">
    {links.map(link => (
      <a href={link.href} class={currentPath === link.href.replace(/\/$/, '') ? 'active' : ''}>
        <span data-lang-en>{link.en}</span>
        <span data-lang-de>{link.de}</span>
      </a>
    ))}
  </div>

  <div class="nav-right">
    <div class="lang-toggle">
      <button class="lang-btn active" data-lang="en">EN</button>
      <button class="lang-btn" data-lang="de">DE</button>
    </div>
    <button class="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<script>
  import { setLang, initLang } from '../scripts/language';
  import { toggleMenu, initMenuCloseOnNav } from '../scripts/menu';

  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = (btn as HTMLElement).dataset.lang as 'en' | 'de';
      setLang(lang);
    });
  });

  document.querySelector('.hamburger')?.addEventListener('click', toggleMenu);

  initLang();
  initMenuCloseOnNav();
</script>
