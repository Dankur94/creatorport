---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Payment Confirmed — CreatorPort HK"
  description="Your booking is confirmed. Welcome to CreatorPort HK!"
>

<section class="success-page">
  <div class="container">

    <!-- Success Animation -->
    <div class="success-icon-wrap">
      <div class="success-circle">
        <svg class="success-check" viewBox="0 0 52 52" fill="none">
          <circle cx="26" cy="26" r="25" stroke="currentColor" stroke-width="2" />
          <path class="check-path" d="M14 27l8 8 16-16" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
    </div>

    <h1 data-lang-en>You're in!</h1>
    <h1 data-lang-de>Du bist dabei!</h1>

    <p class="success-sub" data-lang-en>
      Payment confirmed. A confirmation email is on its way to your inbox.
    </p>
    <p class="success-sub" data-lang-de>
      Zahlung best&auml;tigt. Eine Best&auml;tigungs-E-Mail ist unterwegs.
    </p>

    <!-- Next Steps -->
    <div class="success-steps">
      <h2 data-lang-en>What happens next?</h2>
      <h2 data-lang-de>Wie geht es weiter?</h2>

      <div class="step-list">
        <div class="success-step">
          <div class="step-num">1</div>
          <div>
            <strong data-lang-en>Check your email</strong>
            <strong data-lang-de>E-Mail pr&uuml;fen</strong>
            <p data-lang-en>You'll receive a payment receipt from Stripe and a welcome email from us.</p>
            <p data-lang-de>Du erh&auml;ltst eine Zahlungsbest&auml;tigung von Stripe und eine Willkommens-E-Mail von uns.</p>
          </div>
        </div>
        <div class="success-step">
          <div class="step-num">2</div>
          <div>
            <strong data-lang-en>We'll be in touch</strong>
            <strong data-lang-de>Wir melden uns</strong>
            <p data-lang-en>Daniel will reach out via WhatsApp or email within 24 hours with schedule details.</p>
            <p data-lang-de>Daniel meldet sich innerhalb von 24 Stunden per WhatsApp oder E-Mail mit den Termindetails.</p>
          </div>
        </div>
        <div class="success-step">
          <div class="step-num">3</div>
          <div>
            <strong data-lang-en>Get ready to build!</strong>
            <strong data-lang-de>Bereit zum Bauen!</strong>
            <p data-lang-en>No preparation needed. We provide everything — just bring curiosity.</p>
            <p data-lang-de>Keine Vorbereitung n&ouml;tig. Wir stellen alles bereit &mdash; einfach Neugier mitbringen.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="success-actions">
      <a href="https://wa.me/85265427963?text=Hi%21%20I%20just%20booked%20a%20spot%20at%20CreatorPort%20HK%21" target="_blank" class="btn btn-whatsapp" data-lang-en>
        Say hi on WhatsApp
      </a>
      <a href="https://wa.me/85265427963?text=Hallo%21%20Ich%20habe%20gerade%20einen%20Platz%20bei%20CreatorPort%20HK%20gebucht%21" target="_blank" class="btn btn-whatsapp" data-lang-de>
        Sag Hallo auf WhatsApp
      </a>
      <a href="/" class="btn btn-secondary" data-lang-en>Back to Homepage</a>
      <a href="/" class="btn btn-secondary" data-lang-de>Zur&uuml;ck zur Startseite</a>
    </div>

  </div>
</section>

</PageLayout>

<style>
  .success-page {
    padding: 80px 0 60px;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .success-page .container {
    text-align: center;
  }

  /* Check Icon Animation */
  .success-icon-wrap {
    margin-bottom: 24px;
  }

  .success-circle {
    width: 72px;
    height: 72px;
    margin: 0 auto;
    color: var(--accent);
    animation: scaleIn 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .success-check {
    width: 100%;
    height: 100%;
  }

  .check-path {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: drawCheck 0.6s ease-out 0.3s forwards;
  }

  @keyframes scaleIn {
    from { transform: scale(0); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  .success-page h1 {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 8px;
    animation: fadeUp 0.6s ease-out 0.2s both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .success-sub {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 36px;
    animation: fadeUp 0.6s ease-out 0.3s both;
  }

  /* Next Steps */
  .success-steps {
    text-align: left;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 32px;
    animation: fadeUp 0.6s ease-out 0.4s both;
  }

  .success-steps h2 {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 20px;
    letter-spacing: -0.3px;
  }

  .step-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .success-step {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(15, 110, 86, 0.08);
    color: var(--accent);
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .success-step strong {
    font-size: 14px;
    display: block;
    margin-bottom: 2px;
  }

  .success-step p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Actions */
  .success-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    animation: fadeUp 0.6s ease-out 0.5s both;
  }
</style>
