---
interface Props {
  signedUp?: number;
  goal?: number;
}

const { signedUp = 0, goal = 20 } = Astro.props;
---

<div class="demand-bar reveal" style="max-width:280px;margin:0 auto 24px;">
  <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-muted);margin-bottom:6px;">
    <span class="demand-label"></span><span class="demand-pct"></span>
  </div>
  <div style="height:6px;background:rgba(44,44,42,0.06);border-radius:3px;overflow:hidden;">
    <div class="demand-fill" style="height:100%;border-radius:3px;background:var(--accent-amber);transition:width 1s ease;"></div>
  </div>
</div>

<script define:vars={{ signedUp, goal }}>
  const remaining = goal - signedUp;
  const pct = Math.round((signedUp / goal) * 100);

  // Update counter elements
  document.querySelectorAll('.demand-count-en').forEach(el => el.textContent = remaining.toString());
  document.querySelectorAll('.demand-count-de').forEach(el => el.textContent = remaining.toString());
  document.querySelectorAll('.demand-label').forEach(el => el.textContent = signedUp + ' / ' + goal);
  document.querySelectorAll('.demand-pct').forEach(el => el.textContent = pct + '%');
  document.querySelectorAll('.demand-fill').forEach(el => (el as HTMLElement).style.width = pct + '%');
</script>
