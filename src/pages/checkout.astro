<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Book Now — CreatorPort</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;900&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18308725750"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-18308725750');
  </script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --ink: #181310; --ink-soft: #7A736A; --ink-faint: #B7AFA4; --line: #D6D0C6; --page-bg: #FBFAF8; }
    body { font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif; background: var(--page-bg); color: var(--ink); -webkit-font-smoothing: antialiased; }

    .page-wrap { max-width: 520px; margin: 0 auto; padding: clamp(80px, 12vw, 120px) clamp(20px, 5vw, 40px) 40px; }

    .checkout-header { text-align: center; margin-bottom: 36px; }
    .checkout-header h1 { font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif; font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 600; line-height: 1.1; letter-spacing: -.02em; color: var(--ink); margin-bottom: 8px; }
    .checkout-header p { font-size: clamp(.85rem, 1.8vw, .95rem); color: var(--ink-soft); line-height: 1.6; }

    /* Steps */
    .step { margin-bottom: 28px; }
    .step-label { display: flex; align-items: center; gap: 10px; font-size: .75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .12em; color: var(--ink-faint); margin-bottom: 12px; }
    .step-num { width: 24px; height: 24px; border-radius: 50%; background: var(--ink); color: #fff; font-family: 'Space Grotesk', sans-serif; font-size: .7rem; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }

    /* Program card */
    .program-card { border: 1px solid var(--line); padding: 20px; text-align: center; }
    .program-name { font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif; font-size: clamp(1rem, 2.5vw, 1.15rem); font-weight: 600; color: var(--ink); margin-bottom: 4px; }
    .program-meta { font-size: .82rem; color: var(--ink-soft); }

    /* Details panel */
    .details-panel { border: 1px solid var(--line); display: flex; flex-direction: column; }
    .details-row { display: flex; align-items: center; gap: 12px; padding: 12px 16px; font-size: clamp(.82rem, 1.8vw, .9rem); color: var(--ink-soft); border-bottom: 1px solid var(--line); }
    .details-row:last-child { border-bottom: none; }
    .details-icon { flex-shrink: 0; width: 20px; text-align: center; font-size: .9rem; }

    /* Form */
    .booking-form { display: flex; flex-direction: column; gap: 16px; }
    .form-row { display: flex; gap: 12px; }
    .form-group { flex: 1; display: flex; flex-direction: column; gap: 4px; }
    .form-group-small { flex: 0 0 80px; }
    .form-group label { font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-faint); }
    .form-group input { padding: 12px 14px; border: 1px solid var(--line); background: #fff; font-family: 'Inter', sans-serif; font-size: .9rem; color: var(--ink); transition: border-color .2s; width: 100%; }
    .form-group input:focus { outline: none; border-color: var(--ink); }
    .form-group input::placeholder { color: var(--ink-faint); }

    .form-error { padding: 12px 16px; background: rgba(200,40,40,.06); border: 1px solid rgba(200,40,40,.15); color: #b91c1c; font-size: .82rem; font-weight: 500; display: none; }

    /* Pay button */
    .pay-btn { display: flex; align-items: center; justify-content: center; width: 100%; padding: 18px 24px; border: none; background: var(--ink); color: #fff; font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif; font-weight: 600; font-size: clamp(.95rem, 2.2vw, 1.05rem); letter-spacing: .02em; cursor: pointer; transition: background .2s, transform .15s; -webkit-tap-highlight-color: transparent; }
    .pay-btn:hover:not(:disabled) { background: #2C2520; }
    .pay-btn:active:not(:disabled) { transform: scale(.97); }
    .pay-btn:disabled { opacity: .5; cursor: not-allowed; }
    .trust-line { font-size: .72rem; color: var(--ink-faint); text-align: center; margin-top: 6px; }

    /* FPS Accordion */
    .fps-section { margin-top: 24px; }
    .fps-toggle { width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 14px 20px; background: transparent; border: 1px solid var(--line); font-family: 'Inter', sans-serif; font-size: .8rem; font-weight: 500; color: var(--ink-soft); cursor: pointer; transition: border-color .2s; -webkit-tap-highlight-color: transparent; }
    .fps-toggle:hover { border-color: var(--ink-faint); }
    .fps-chevron { font-size: .6rem; transition: transform .3s; }
    .fps-section.open .fps-chevron { transform: rotate(180deg); }
    .fps-body { max-height: 0; overflow: hidden; transition: max-height .4s cubic-bezier(.16,1,.3,1); }
    .fps-section.open .fps-body { max-height: 400px; }
    .fps-inner { display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 24px 16px 8px; text-align: center; }
    .fps-qr { background: #fff; padding: 10px; border: 1px solid var(--line); }
    .fps-qr img { display: block; }
    .fps-id { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: center; }
    .fps-id-label { font-size: .72rem; color: var(--ink-faint); font-weight: 600; text-transform: uppercase; letter-spacing: .08em; }
    .fps-id-number { font-family: 'Space Grotesk', monospace; font-size: 1.1rem; font-weight: 700; letter-spacing: 2px; color: var(--ink); }
    .fps-copy-btn { padding: 5px 12px; border: 1px solid var(--line); background: transparent; font-family: 'Inter', sans-serif; font-size: .7rem; font-weight: 600; color: var(--ink-soft); cursor: pointer; transition: border-color .2s; }
    .fps-copy-btn:hover { border-color: var(--ink); color: var(--ink); }
    .fps-copied { font-size: .8rem; color: var(--ink); opacity: 0; transition: opacity .3s; }
    .fps-copied.show { opacity: 1; }
    .fps-wa-btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: #25D366; color: #fff; font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: .85rem; text-decoration: none; transition: background .2s; }
    .fps-wa-btn:hover { background: #1DA851; }

    /* Help */
    .checkout-help { text-align: center; margin-top: 32px; font-size: .82rem; color: var(--ink-faint); }
    .checkout-help a { color: var(--ink); text-decoration: none; font-weight: 600; }
    .checkout-help a:hover { text-decoration: underline; }

    /* Burger + Menu */
    .burger { position: fixed; top: clamp(16px, 4vw, 32px); right: clamp(16px, 4vw, 32px); z-index: 100; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer; -webkit-tap-highlight-color: transparent; padding: 0; }
    .burger-line { display: block; width: 28px; height: 3px; background: var(--ink); border-radius: 2px; position: relative; transition: transform .3s ease, opacity .3s ease; }
    .menu-overlay { position: fixed; inset: 0; z-index: 99; background: var(--page-bg); display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 32px; opacity: 0; pointer-events: none; transition: opacity .3s ease; }
    .menu-overlay.open { opacity: 1; pointer-events: auto; }
    .menu-overlay nav { display: flex; flex-direction: column; align-items: center; gap: 24px; }
    .menu-link { font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif; font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 600; color: var(--ink); text-decoration: none; letter-spacing: -.02em; transition: opacity .2s ease; }
    .menu-link:hover { opacity: .5; }
    .menu-legal { display: flex; gap: 16px; }
    .menu-legal a { font-size: .8rem; font-weight: 500; color: var(--ink-faint); text-decoration: none; letter-spacing: .04em; }
    .menu-legal a:hover { color: var(--ink); }
    .burger.is-open .burger-line { background: transparent; }
    .burger.is-open .burger-line::before, .burger.is-open .burger-line::after { content: ''; position: absolute; width: 28px; height: 3px; background: var(--ink); border-radius: 2px; }
    .burger.is-open .burger-line::before { transform: rotate(45deg); }
    .burger.is-open .burger-line::after { transform: rotate(-45deg); }
    .mini-footer { text-align: center; padding: 32px 20px; font-size: .7rem; color: var(--ink-faint); border-top: 1px solid var(--line); }
    .mini-footer a { color: var(--ink-faint); text-decoration: none; }
    .mini-footer a:hover { color: var(--ink); }
  </style>
</head>
<body>
  <button class="burger" aria-label="Menu"><span class="burger-line"></span></button>
  <div class="menu-overlay">
    <nav>
      <a class="menu-link" href="/">Home</a>
      <a class="menu-link" href="/location.html">Location</a>
      <a class="menu-link" href="/our-story.html">Our Story</a>
      <a class="menu-link" href="/about-us.html">About Us</a>
      <a class="menu-link" href="/mars-rover.html">Mars Rover EK10</a>
    </nav>
    <div class="menu-legal">
      <a href="/privacy.html">Privacy</a>
      <a href="/terms.html">Terms</a>
    </div>
  </div>

  <main class="page-wrap">
    <div class="checkout-header">
      <h1>Book a Spot</h1>
      <p>Fill in details, pay securely via Stripe.</p>
    </div>

    <!-- Step 1: Program -->
    <div class="step">
      <div class="step-label"><span class="step-num">1</span> Program</div>
      <div class="program-card">
        <div class="program-name" id="programName">Mission Mars Summer Camp</div>
        <div class="program-meta" id="programMeta">Summer Camp · HK$3,500</div>
      </div>
    </div>

    <!-- Step 2: Camp Details -->
    <div class="step">
      <div class="step-label"><span class="step-num">2</span> Camp Details</div>
      <div class="details-panel" id="programDetails">
        <div class="details-row"><span class="details-icon">📅</span><span>3–7 August 2026, Mon–Fri, 9:00 am – 12:00 pm</span></div>
        <div class="details-row"><span class="details-icon">📍</span><span>19/F Amtel Building, 144–148 Des Voeux Rd Central</span></div>
        <div class="details-row"><span class="details-icon">🧒</span><span>Ages 6–12</span></div>
        <div class="details-row"><span class="details-icon">🤖</span><span>Mars rover included — your child takes it home</span></div>
      </div>
    </div>

    <!-- Step 3: Your Details -->
    <div class="step">
      <div class="step-label"><span class="step-num">3</span> Your Details</div>
      <form id="bookingForm" class="booking-form">
        <div class="form-row">
          <div class="form-group">
            <label>Child's Name *</label>
            <input type="text" id="childName" required placeholder="e.g. Max" />
          </div>
          <div class="form-group form-group-small">
            <label>Age *</label>
            <input type="number" id="childAge" required min="1" max="18" placeholder="8" />
          </div>
        </div>
        <div class="form-group">
          <label>Parent / Guardian Name *</label>
          <input type="text" id="customerName" required placeholder="e.g. John Smith" />
        </div>
        <div class="form-group">
          <label>Email *</label>
          <input type="email" id="customerEmail" required placeholder="parent@example.com" />
        </div>
        <div class="form-group">
          <label>Phone (WhatsApp preferred)</label>
          <input type="tel" id="customerPhone" placeholder="+852 1234 5678" />
        </div>

        <div id="formError" class="form-error"></div>

        <button type="submit" class="pay-btn" id="payBtn">Pay HK$3,500 — Apple Pay / Card</button>
        <div class="trust-line">Secure payment via Stripe · 100% money-back guarantee</div>
      </form>
    </div>

    <!-- FPS Alternative -->
    <div class="fps-section" id="fpsSection">
      <button class="fps-toggle" id="fpsToggle" type="button">
        Prefer bank transfer? Pay via FPS (no fees)
        <span class="fps-chevron">▾</span>
      </button>
      <div class="fps-body">
        <div class="fps-inner">
          <div class="fps-qr">
            <img src="/img/fps-qr.jpg" alt="FPS QR Code" width="120" height="120" />
          </div>
          <div class="fps-id">
            <span class="fps-id-label">FPS ID:</span>
            <span class="fps-id-number">126847250</span>
            <button class="fps-copy-btn" id="fpsCopyBtn" type="button">Copy</button>
            <span class="fps-copied" id="fpsCopied">✓</span>
          </div>
          <a href="https://wa.me/85265427963?text=Hi%21%20I%27ve%20paid%20via%20FPS.%0A-%20Child%27s%20name%3A%0A-%20Age%3A%0A-%20Program%3A%20Mission%20Mars%0A-%20FPS%20reference%3A" target="_blank" class="fps-wa-btn">
            Confirm on WhatsApp
          </a>
        </div>
      </div>
    </div>

    <!-- Help -->
    <div class="checkout-help">
      <p>Questions? <a href="https://wa.me/85265427963" target="_blank">Chat on WhatsApp</a> or email <a href="mailto:daniel@creatorport.com.hk">daniel@creatorport.com.hk</a></p>
    </div>
  </main>

  <footer class="mini-footer">
    Space of Possibilities Ltd. · Hong Kong · <a href="/privacy.html">Privacy</a> · <a href="/terms.html">Terms</a> · <a href="https://wa.me/85265427963">Contact</a>
  </footer>

<script>
  // Burger menu
  const burger = document.querySelector('.burger');
  const overlay = document.querySelector('.menu-overlay');
  burger.addEventListener('click', () => {
    const open = overlay.classList.toggle('open');
    burger.classList.toggle('is-open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  });

  // Form submission → Stripe Payment Link with prefilled email
  const form = document.getElementById('bookingForm');
  const payBtn = document.getElementById('payBtn');
  const errorEl = document.getElementById('formError');

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    const childName = document.getElementById('childName').value.trim();
    const childAge = parseInt(document.getElementById('childAge').value, 10);
    const customerName = document.getElementById('customerName').value.trim();
    const customerEmail = document.getElementById('customerEmail').value.trim();
    const customerPhone = (document.getElementById('customerPhone').value || '').trim();

    if (!childName || !childAge || !customerName || !customerEmail) {
      showError('Please fill in all required fields.');
      return;
    }

    payBtn.disabled = true;
    payBtn.textContent = 'Redirecting to payment...';

    // Build Stripe Payment Link with prefilled email and metadata via client_reference_id
    const ref = encodeURIComponent(JSON.stringify({
      child: childName,
      age: childAge,
      parent: customerName,
      phone: customerPhone
    }));

    const stripeUrl = 'https://buy.stripe.com/dRmaEWa9KaRMgTZ7hz4c800'
      + '?prefilled_email=' + encodeURIComponent(customerEmail)
      + '&client_reference_id=' + ref;

    window.location.href = stripeUrl;
  });

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.style.display = 'block';
    setTimeout(function() { errorEl.style.display = 'none'; }, 6000);
  }

  // FPS Accordion
  const fpsToggle = document.getElementById('fpsToggle');
  const fpsSection = document.getElementById('fpsSection');
  fpsToggle.addEventListener('click', function() {
    fpsSection.classList.toggle('open');
  });

  // FPS Copy
  document.getElementById('fpsCopyBtn').addEventListener('click', function() {
    navigator.clipboard.writeText('126847250').then(function() {
      const copied = document.getElementById('fpsCopied');
      copied.classList.add('show');
      setTimeout(function() { copied.classList.remove('show'); }, 2000);
    });
  });
</script>
<script>
  // WhatsApp click conversion tracking
  document.querySelectorAll('a[href*="wa.me"]').forEach(function(link) {
    link.addEventListener('click', function() {
      gtag('event', 'conversion', {
        'send_to': 'AW-18308725750/bCRrCN_g6M4cEPb3o5pE'
      });
    });
  });
</script>
</body>
</html>
