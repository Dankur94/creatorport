---
import PageLayout from '../layouts/PageLayout.astro';

/*
 * ============================================================
 *  STRIPE PAYMENT LINKS — SETUP
 * ============================================================
 *  Replace the placeholder URLs below with your real Stripe
 *  Payment Link URLs. See /docs/STRIPE-SETUP.md for details.
 *
 *  1. Create Payment Links in Stripe Dashboard
 *  2. Add custom fields: Child's Name, Age, Language (EN/DE)
 *  3. Set success redirect to: https://creatorport.com.hk/success
 *  4. Paste URLs below
 * ============================================================
 */
const STRIPE_LINKS = {
  camp: 'https://buy.stripe.com/REPLACE_WITH_CAMP_LINK',
  tlp:  'https://buy.stripe.com/REPLACE_WITH_TLP_LINK',
};
---

<PageLayout
  title="Book Now — CreatorPort HK"
  description="Book your child's spot in our AI & Robotics programs. Pay securely with Apple Pay, credit card, or FPS."
  navCta={{ href: 'https://wa.me/85265427963', en: 'Help', de: 'Hilfe' }}
>

<section class="checkout-page">
  <div class="checkout-container">

    <!-- Header -->
    <div class="checkout-header">
      <h1 data-lang-en>Book a Spot</h1>
      <h1 data-lang-de>Platz buchen</h1>
      <p data-lang-en>Choose a program and pay securely. Apple&nbsp;Pay, credit&nbsp;card, or FPS.</p>
      <p data-lang-de>Programm w&auml;hlen und sicher bezahlen. Apple&nbsp;Pay, Kreditkarte oder FPS.</p>
    </div>

    <!-- Program Cards -->
    <div class="checkout-programs">

      <!-- Camp Card -->
      <div class="checkout-card" id="card-camp" data-program="camp">
        <div class="checkout-card-badge" data-lang-en>Most Popular</div>
        <div class="checkout-card-badge" data-lang-de>Beliebtestes</div>
        <div class="checkout-card-icon"></div>
        <h2>Make Mars Green</h2>
        <div class="checkout-card-sub" data-lang-en>3&ndash;7 Aug &middot; Mon&ndash;Fri &middot; 9:00&ndash;12:00</div>
        <div class="checkout-card-sub" data-lang-de>3.&ndash;7. Aug &middot; Mo&ndash;Fr &middot; 9:00&ndash;12:00</div>
        <div class="checkout-card-details">
          <span data-lang-en>5 days &times; 3 hours &middot; Central, Hong Kong &middot; all materials included</span>
          <span data-lang-de>5 Tage &times; 3 Std. &middot; Central, Hong Kong &middot; alle Materialien inklusive</span>
        </div>
        <div class="checkout-card-price">
          <span class="price-big">$3,000</span>
          <span class="price-currency">HKD</span>
        </div>
        <ul class="checkout-card-features">
          <li data-lang-en>Age 5&ndash;7 &middot; Age 8&ndash;12</li>
          <li data-lang-de>Alter 5&ndash;7 &middot; Alter 8&ndash;12</li>
          <li data-lang-en>English or German</li>
          <li data-lang-de>Englisch oder Deutsch</li>
          <li data-lang-en>Central, Hong Kong</li>
          <li data-lang-de>Central, Hong Kong</li>
          <li data-lang-en>Kids keep what they build</li>
          <li data-lang-de>Kinder behalten, was sie bauen</li>
        </ul>
        <a href={STRIPE_LINKS.camp} class="checkout-pay-btn" data-program="camp">
          <span class="pay-icon" data-lang-en> Pay with Apple Pay / Card</span>
          <span class="pay-icon" data-lang-de> Mit Apple Pay / Karte bezahlen</span>
        </a>
        <div class="checkout-card-trust" data-lang-en>Secure payment via Stripe. 256-bit encryption.</div>
        <div class="checkout-card-trust" data-lang-de>Sichere Zahlung &uuml;ber Stripe. 256-Bit-Verschl&uuml;sselung.</div>
      </div>

      <!-- TLP Card -->
      <div class="checkout-card" id="card-tlp" data-program="tlp">
        <div class="checkout-card-icon"></div>
        <h2>Think. Learn. Present.</h2>
        <div class="checkout-card-sub" data-lang-en>Online &middot; Ages 14+</div>
        <div class="checkout-card-sub" data-lang-de>Online &middot; Ab 14 Jahre</div>
        <div class="checkout-card-details">
          <span data-lang-en>8 sessions &times; 60 min &middot; $450 HKD / session</span>
          <span data-lang-de>8 Sitzungen &times; 60 Min. &middot; $450 HKD / Sitzung</span>
        </div>
        <div class="checkout-card-price">
          <span class="price-big">$3,600</span>
          <span class="price-currency">HKD / module</span>
        </div>
        <ul class="checkout-card-features">
          <li data-lang-en>Max 6 students</li>
          <li data-lang-de>Max. 6 Sch&uuml;ler</li>
          <li data-lang-en>Memory techniques &amp; learning science</li>
          <li data-lang-de>Ged&auml;chtnistechniken &amp; Lernwissenschaft</li>
          <li data-lang-en>Presentation coaching &amp; feedback</li>
          <li data-lang-de>Pr&auml;sentations-Coaching &amp; Feedback</li>
          <li data-lang-en>Demo Day &amp; certificate</li>
          <li data-lang-de>Demo Day &amp; Zertifikat</li>
        </ul>
        <a href={STRIPE_LINKS.tlp} class="checkout-pay-btn secondary" data-program="tlp">
          <span class="pay-icon" data-lang-en> Pay with Apple Pay / Card</span>
          <span class="pay-icon" data-lang-de> Mit Apple Pay / Karte bezahlen</span>
        </a>
        <div class="checkout-card-trust" data-lang-en>Secure payment via Stripe. 256-bit encryption.</div>
        <div class="checkout-card-trust" data-lang-de>Sichere Zahlung &uuml;ber Stripe. 256-Bit-Verschl&uuml;sselung.</div>
      </div>
    </div>

    <!-- FPS Alternative -->
    <div class="checkout-fps-section">
      <div class="checkout-fps-divider">
        <span data-lang-en>or pay via FPS (no fees)</span>
        <span data-lang-de>oder per FPS bezahlen (keine Geb&uuml;hren)</span>
      </div>
      <div class="checkout-fps-card">
        <div class="checkout-fps-inner">
          <div class="checkout-fps-qr">
            <img src="/img/fps-qr.jpg" alt="FPS QR Code" width="160" height="160" />
          </div>
          <div class="checkout-fps-info">
            <h3 data-lang-en>Scan with your banking app</h3>
            <h3 data-lang-de>Mit Banking-App scannen</h3>
            <p data-lang-en>Pay via FPS using HSBC, Hang Seng, BOC, or any HK bank.</p>
            <p data-lang-de>Per FPS bezahlen &uuml;ber HSBC, Hang Seng, BOC oder jede HK-Bank.</p>
            <div class="fps-id-row">
              <span class="fps-label">FPS ID:</span>
              <span class="fps-number" id="fpsNumber">126847250</span>
              <button class="fps-copy" id="fpsCopyBtn" type="button" data-lang-en>Copy</button>
              <button class="fps-copy" id="fpsCopyBtn2" type="button" data-lang-de>Kopieren</button>
              <span class="fps-copied" id="fpsCopied">&#x2713;</span>
            </div>
            <a href="https://wa.me/85265427963?text=Hi%21%20I%27ve%20paid%20via%20FPS.%0A-%20Child%27s%20name%3A%0A-%20Age%3A%0A-%20Program%3A%0A-%20FPS%20reference%3A" target="_blank" class="fps-confirm-btn" data-lang-en>
              Confirm payment on WhatsApp
            </a>
            <a href="https://wa.me/85265427963?text=Hallo%21%20Ich%20habe%20per%20FPS%20bezahlt.%0A-%20Name%20des%20Kindes%3A%0A-%20Alter%3A%0A-%20Programm%3A%0A-%20FPS-Referenz%3A" target="_blank" class="fps-confirm-btn" data-lang-de>
              Zahlung per WhatsApp best&auml;tigen
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust Signals -->
    <div class="checkout-trust">
      <div class="trust-item">
        <span class="trust-icon"></span>
        <span data-lang-en>100% money-back guarantee</span>
        <span data-lang-de>100% Geld-zur&uuml;ck-Garantie</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon"></span>
        <span data-lang-en>Secure payment</span>
        <span data-lang-de>Sichere Zahlung</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon"></span>
        <span data-lang-en>Instant confirmation</span>
        <span data-lang-de>Sofortige Best&auml;tigung</span>
      </div>
    </div>

    <!-- Help -->
    <div class="checkout-help">
      <p data-lang-en>Questions? <a href="https://wa.me/85265427963" target="_blank">Chat on WhatsApp</a> or email <a href="mailto:hello@creatorport.com.hk">hello@creatorport.com.hk</a></p>
      <p data-lang-de>Fragen? <a href="https://wa.me/85265427963" target="_blank">Chat auf WhatsApp</a> oder E-Mail an <a href="mailto:hello@creatorport.com.hk">hello@creatorport.com.hk</a></p>
    </div>

  </div>
</section>

</PageLayout>

<style>
  .checkout-page {
    padding: 120px 24px 80px;
    min-height: 100vh;
  }

  .checkout-container {
    max-width: 800px;
    margin: 0 auto;
  }

  /* Header */
  .checkout-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .checkout-header h1 {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -2px;
    margin-bottom: 12px;
  }

  .checkout-header p {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 400px;
    margin: 0 auto;
  }

  /* Program Cards */
  .checkout-programs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 48px;
  }

  .checkout-card {
    background: var(--bg-card);
    border: 2px solid var(--border-subtle);
    border-radius: 20px;
    padding: 32px 24px;
    position: relative;
    transition: all 0.3s;
  }

  .checkout-card:first-child {
    border-color: var(--accent-electric);
  }

  .checkout-card-badge {
    position: absolute;
    top: -12px;
    left: 24px;
    background: var(--accent-electric);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 14px;
    border-radius: 100px;
  }

  .checkout-card-icon {
    font-size: 36px;
    margin-bottom: 16px;
  }

  .checkout-card h2 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 4px;
  }

  .checkout-card-sub {
    font-size: 13px;
    color: var(--accent-electric);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .checkout-card-details {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }

  .checkout-card-price {
    margin-bottom: 20px;
  }

  .price-big {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -1.5px;
  }

  .price-currency {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 400;
  }

  .checkout-card-features {
    list-style: none;
    margin-bottom: 24px;
  }

  .checkout-card-features li {
    font-size: 13px;
    color: var(--text-secondary);
    padding: 4px 0;
    padding-left: 20px;
    position: relative;
  }

  .checkout-card-features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--accent-amber);
    font-weight: 700;
  }

  /* Pay Button */
  .checkout-pay-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 16px 24px;
    border-radius: 14px;
    background: #000;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: 16px;
    text-decoration: none;
    transition: all 0.3s;
    gap: 8px;
    min-height: 54px;
    -webkit-tap-highlight-color: transparent;
  }

  .checkout-pay-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .checkout-pay-btn:active {
    transform: translateY(0);
  }

  .checkout-pay-btn.secondary {
    background: var(--accent-electric);
  }

  .checkout-pay-btn.secondary:hover {
    background: #0A5A45;
    box-shadow: 0 8px 32px rgba(15, 110, 86, 0.3);
  }

  .pay-icon {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .checkout-card-trust {
    font-size: 11px;
    color: var(--text-muted);
    text-align: center;
    margin-top: 12px;
  }

  /* FPS Section */
  .checkout-fps-section {
    margin-bottom: 48px;
  }

  .checkout-fps-divider {
    text-align: center;
    position: relative;
    margin-bottom: 24px;
  }

  .checkout-fps-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border-subtle);
  }

  .checkout-fps-divider span {
    position: relative;
    background: var(--bg-primary);
    padding: 0 20px;
    font-size: 13px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .checkout-fps-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    padding: 32px;
  }

  .checkout-fps-inner {
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .checkout-fps-qr {
    flex-shrink: 0;
    background: #fff;
    border-radius: 12px;
    padding: 12px;
  }

  .checkout-fps-qr img {
    display: block;
    border-radius: 8px;
  }

  .checkout-fps-info h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.5px;
  }

  .checkout-fps-info p {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .fps-id-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .fps-label {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 600;
  }

  .fps-number {
    font-family: 'Space Mono', monospace;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .fps-copy {
    padding: 6px 14px;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    background: transparent;
    font-family: 'Sora', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent-electric);
    cursor: pointer;
    transition: all 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .fps-copy:hover {
    background: rgba(15, 110, 86, 0.05);
    border-color: var(--accent-electric);
  }

  .fps-copied {
    font-size: 14px;
    color: var(--accent-electric);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .fps-copied.show {
    opacity: 1;
  }

  .fps-confirm-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: #25D366;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: 14px;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.3s;
    min-height: 44px;
  }

  .fps-confirm-btn:hover {
    background: #1DA851;
    transform: translateY(-1px);
  }

  /* Trust Signals */
  .checkout-trust {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .trust-icon {
    font-size: 18px;
  }

  /* Help */
  .checkout-help {
    text-align: center;
    font-size: 14px;
    color: var(--text-muted);
  }

  .checkout-help a {
    color: var(--accent-electric);
    text-decoration: underline;
    font-weight: 600;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .checkout-page {
      padding: 100px 16px 60px;
    }

    .checkout-header h1 {
      font-size: 32px;
      letter-spacing: -1px;
    }

    .checkout-programs {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .checkout-card {
      padding: 28px 20px;
    }

    .price-big {
      font-size: 32px;
    }

    .checkout-fps-inner {
      flex-direction: column;
      text-align: center;
    }

    .fps-id-row {
      justify-content: center;
    }

    .checkout-trust {
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }
  }

  /* Highlight on URL param */
  .checkout-card.selected {
    border-color: var(--accent-electric);
    box-shadow: 0 4px 24px rgba(15, 110, 86, 0.12);
  }
</style>

<script>
  // Auto-select program from URL param (?program=camp or ?program=tlp)
  const params = new URLSearchParams(window.location.search);
  const program = params.get('program');

  if (program === 'camp' || program === 'tlp') {
    const card = document.getElementById(`card-${program}`);
    if (card) {
      card.classList.add('selected');
      card.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  // FPS Copy
  document.querySelectorAll('#fpsCopyBtn, #fpsCopyBtn2').forEach(btn => {
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText('126847250').then(() => {
        const copied = document.getElementById('fpsCopied');
        if (copied) {
          copied.classList.add('show');
          setTimeout(() => copied.classList.remove('show'), 2000);
        }
      });
    });
  });
</script>
