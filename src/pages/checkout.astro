---
import PageLayout from '../layouts/PageLayout.astro';

/*
 * ============================================================
 *  STRIPE PAYMENT LINKS — SETUP
 * ============================================================
 *  Replace the placeholder URLs below with your real Stripe
 *  Payment Link URLs. See /docs/STRIPE-SETUP.md for details.
 *
 *  Stripe Payment Links support ?quantity=N parameter.
 *  The JS below appends the total child count automatically.
 *
 *  1. Create Payment Links in Stripe Dashboard
 *  2. Add custom fields: Child names, Ages, Language (EN/DE)
 *  3. Set success redirect to: https://creatorport.com.hk/success
 *  4. Paste URLs below
 * ============================================================
 */
const STRIPE_LINKS = {
  camp: 'https://buy.stripe.com/REPLACE_WITH_CAMP_LINK',
};

const CAMP_PRICE = 3500;
---

<PageLayout
  title="Book Now — CreatorPort HK"
  description="Book your child's spot in our AI & Robotics programs. Pay securely with Apple Pay, credit card, or FPS."
  navCta={{ href: 'https://wa.me/85265427963', en: 'Help', de: 'Hilfe' }}
>

<section class="checkout-page">
  <div class="checkout-container">

    <!-- Header -->
    <div class="checkout-header">
      <h1 data-lang-en>Book a Spot</h1>
      <h1 data-lang-de>Platz buchen</h1>
      <p data-lang-en>Choose a program, select children, pay securely.</p>
      <p data-lang-de>Programm w&auml;hlen, Kinder ausw&auml;hlen, sicher bezahlen.</p>
    </div>

    <!-- Step 1: Program Info -->
    <div class="step-section">
      <div class="step-label"><span class="step-num">1</span> <span data-lang-en>Program</span><span data-lang-de>Programm</span></div>
      <div class="program-tabs">
        <button class="program-tab active" data-tab="camp" type="button">
          <span class="tab-icon"></span>
          <span class="tab-name">Make Mars Green</span>
          <span class="tab-meta" data-lang-en>Summer Camp &middot; $3,500</span>
          <span class="tab-meta" data-lang-de>Sommercamp &middot; $3.500</span>
        </button>
      </div>
    </div>

    <!-- Step 2: Camp Details + Child Counter -->
    <div class="step-section" id="step-details">

      <!-- CAMP panel -->
      <div class="program-panel active" id="panel-camp">
        <div class="step-label"><span class="step-num">2</span> <span data-lang-en>How many children?</span><span data-lang-de>Wie viele Kinder?</span></div>
        <div class="panel-info">
          <div class="panel-info-row">
            <span class="panel-info-icon"></span>
            <span data-lang-en>3&ndash;7 Aug 2026 &middot; Mon&ndash;Fri &middot; 9:00&ndash;12:00</span>
            <span data-lang-de>3.&ndash;7. Aug 2026 &middot; Mo&ndash;Fr &middot; 9:00&ndash;12:00</span>
          </div>
          <div class="panel-info-row">
            <span class="panel-info-icon"></span>
            <span>Central, Hong Kong</span>
          </div>
          <div class="panel-info-row">
            <span class="panel-info-icon"></span>
            <span data-lang-en>All materials included &middot; Kids keep what they build</span>
            <span data-lang-de>Alle Materialien inklusive &middot; Kinder behalten, was sie bauen</span>
          </div>
        </div>

        <!-- Age Group Counter -->
        <div class="age-groups">
          <div class="age-group">
            <div class="age-group-info">
              <div class="age-group-name" data-lang-en>Age 5&ndash;12</div>
              <div class="age-group-name" data-lang-de>Alter 5&ndash;12</div>
              <div class="age-group-price">$3,500 <span>HKD</span></div>
            </div>
            <div class="counter">
              <button class="counter-btn minus" data-group="camp" type="button" disabled>&minus;</button>
              <span class="counter-value" id="count-camp">0</span>
              <button class="counter-btn plus" data-group="camp" type="button">+</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Booking Summary (hidden until items selected) -->
    <div class="summary-section" id="bookingSummary" style="display: none;">
      <div class="step-label"><span class="step-num">3</span> <span data-lang-en>Booking summary</span><span data-lang-de>Buchungs&uuml;bersicht</span></div>
      <div class="summary-card">
        <div class="summary-lines" id="summaryLines">
          <!-- filled by JS -->
        </div>
        <div class="summary-divider"></div>
        <div class="summary-total">
          <span data-lang-en>Total</span><span data-lang-de>Gesamt</span>
          <span class="summary-total-amount" id="summaryTotal">$0 HKD</span>
        </div>

        <!-- Pay Button -->
        <a href="#" class="checkout-pay-btn" id="payBtn">
          <span data-lang-en>Pay <span id="payAmountEn">$0 HKD</span> &mdash; Apple Pay / Card</span>
          <span data-lang-de><span id="payAmountDe">$0 HKD</span> bezahlen &mdash; Apple Pay / Karte</span>
        </a>
        <div class="summary-trust">
          <span data-lang-en>Secure payment via Stripe &middot; 100% money-back guarantee</span>
          <span data-lang-de>Sichere Zahlung via Stripe &middot; 100% Geld-zur&uuml;ck-Garantie</span>
        </div>
      </div>
    </div>

    <!-- Empty state hint -->
    <div class="empty-hint" id="emptyHint">
      <p data-lang-en>Select at least one child above to continue.</p>
      <p data-lang-de>W&auml;hle oben mindestens ein Kind aus, um fortzufahren.</p>
    </div>

    <!-- FPS Alternative (collapsible) -->
    <div class="fps-accordion">
      <button class="fps-toggle" id="fpsToggle" type="button">
        <span data-lang-en>Prefer bank transfer? Pay via FPS (no fees)</span>
        <span data-lang-de>Lieber per Bank? Per FPS bezahlen (keine Geb&uuml;hren)</span>
        <span class="fps-chevron">&#9662;</span>
      </button>
      <div class="fps-collapse" id="fpsCollapse">
        <div class="fps-collapse-inner">
          <div class="fps-qr-wrap">
            <img src="/img/fps-qr.jpg" alt="FPS QR Code" width="120" height="120" />
          </div>
          <div class="fps-id-row">
            <span class="fps-label">FPS ID:</span>
            <span class="fps-number">126847250</span>
            <button class="fps-copy" id="fpsCopyBtn" type="button" data-lang-en>Copy</button>
            <button class="fps-copy" id="fpsCopyBtn2" type="button" data-lang-de>Kopieren</button>
            <span class="fps-copied" id="fpsCopied">&#x2713;</span>
          </div>
          <a href="https://wa.me/85265427963?text=Hi%21%20I%27ve%20paid%20via%20FPS.%0A-%20Child%27s%20name%3A%0A-%20Age%3A%0A-%20Program%3A%0A-%20FPS%20reference%3A" target="_blank" class="fps-confirm-btn" data-lang-en>
            Confirm on WhatsApp
          </a>
          <a href="https://wa.me/85265427963?text=Hallo%21%20Ich%20habe%20per%20FPS%20bezahlt.%0A-%20Name%20des%20Kindes%3A%0A-%20Alter%3A%0A-%20Programm%3A%0A-%20FPS-Referenz%3A" target="_blank" class="fps-confirm-btn" data-lang-de>
            Per WhatsApp best&auml;tigen
          </a>
        </div>
      </div>
    </div>

    <!-- Help -->
    <div class="checkout-help">
      <p data-lang-en>Questions? <a href="https://wa.me/85265427963" target="_blank">Chat on WhatsApp</a> or email <a href="mailto:hello@creatorport.com.hk">hello@creatorport.com.hk</a></p>
      <p data-lang-de>Fragen? <a href="https://wa.me/85265427963" target="_blank">Chat auf WhatsApp</a> oder E-Mail an <a href="mailto:hello@creatorport.com.hk">hello@creatorport.com.hk</a></p>
    </div>

  </div>
</section>

</PageLayout>

<style>
  .checkout-page {
    padding: 120px 24px 80px;
    min-height: 100vh;
  }

  .checkout-container {
    max-width: 640px;
    margin: 0 auto;
  }

  /* Header */
  .checkout-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .checkout-header h1 {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -2px;
    margin-bottom: 8px;
  }

  .checkout-header p {
    font-size: 15px;
    color: var(--text-secondary);
  }

  /* Steps */
  .step-section {
    margin-bottom: 32px;
  }

  .step-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--accent-electric);
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Program Tabs */
  .program-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .program-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 20px 16px;
    background: var(--bg-card);
    border: 2px solid var(--border-subtle);
    border-radius: 16px;
    cursor: pointer;
    transition: all 0.25s;
    font-family: 'Sora', sans-serif;
    -webkit-tap-highlight-color: transparent;
  }

  .program-tab:hover {
    border-color: rgba(15, 110, 86, 0.3);
  }

  .program-tab.active {
    border-color: var(--accent-electric);
    background: rgba(15, 110, 86, 0.04);
    box-shadow: 0 2px 16px rgba(15, 110, 86, 0.1);
  }

  .tab-icon {
    font-size: 28px;
    line-height: 1;
  }

  .tab-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.3px;
  }

  .tab-meta {
    font-size: 12px;
    color: var(--text-muted);
  }

  /* Program Panel */
  .program-panel {
    display: none;
  }

  .program-panel.active {
    display: block;
  }

  .panel-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px;
    background: rgba(15, 110, 86, 0.04);
    border: 1px solid rgba(15, 110, 86, 0.1);
    border-radius: 14px;
    margin-bottom: 20px;
  }

  .panel-info-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--text-secondary);
  }

  .panel-info-icon {
    font-size: 16px;
    flex-shrink: 0;
    width: 20px;
    text-align: center;
  }

  /* Age Group Counters */
  .age-groups {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .age-group {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    transition: border-color 0.2s;
  }

  .age-group.has-count {
    border-color: var(--accent-electric);
    background: rgba(15, 110, 86, 0.02);
  }

  .age-group-name {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 2px;
  }

  .age-group-price {
    font-size: 14px;
    color: var(--text-muted);
  }

  .age-group-price span {
    font-size: 12px;
  }

  /* Counter */
  .counter {
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(44, 44, 42, 0.04);
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
    overflow: hidden;
  }

  .counter-btn {
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Sora', sans-serif;
    -webkit-tap-highlight-color: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .counter-btn:hover:not(:disabled) {
    background: rgba(15, 110, 86, 0.08);
    color: var(--accent-electric);
  }

  .counter-btn:active:not(:disabled) {
    background: rgba(15, 110, 86, 0.15);
  }

  .counter-btn:disabled {
    opacity: 0.25;
    cursor: default;
  }

  .counter-value {
    width: 40px;
    text-align: center;
    font-family: 'Space Mono', monospace;
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    border-left: 1px solid var(--border-subtle);
    border-right: 1px solid var(--border-subtle);
    line-height: 44px;
  }

  /* Summary */
  .summary-section {
    margin-bottom: 32px;
    animation: slideUp 0.3s ease-out;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .summary-card {
    background: var(--bg-card);
    border: 2px solid var(--accent-electric);
    border-radius: 20px;
    padding: 24px;
  }

  .summary-lines {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .summary-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 15px;
  }

  .summary-line-label {
    color: var(--text-secondary);
  }

  .summary-line-label strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .summary-line-price {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 15px;
    white-space: nowrap;
  }

  .summary-divider {
    height: 1px;
    background: var(--border-subtle);
    margin: 16px 0;
  }

  .summary-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 24px;
  }

  .summary-total-amount {
    font-family: 'Space Mono', monospace;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -1px;
    color: var(--accent-electric);
  }

  /* Pay Button */
  .checkout-pay-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 18px 24px;
    border-radius: 14px;
    background: #000;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: 17px;
    text-decoration: none;
    transition: all 0.3s;
    gap: 8px;
    min-height: 56px;
    -webkit-tap-highlight-color: transparent;
  }

  .checkout-pay-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .checkout-pay-btn:active {
    transform: translateY(0);
  }

  .summary-trust {
    font-size: 12px;
    color: var(--text-muted);
    text-align: center;
    margin-top: 12px;
  }

  /* Empty hint */
  .empty-hint {
    text-align: center;
    padding: 24px;
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 32px;
  }

  /* FPS Accordion */
  .fps-accordion {
    margin-bottom: 40px;
  }

  .fps-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 20px;
    background: transparent;
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    font-family: 'Sora', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .fps-toggle:hover {
    border-color: rgba(15, 110, 86, 0.3);
    color: var(--text-secondary);
  }

  .fps-chevron {
    font-size: 10px;
    transition: transform 0.3s;
  }

  .fps-accordion.open .fps-chevron {
    transform: rotate(180deg);
  }

  .fps-collapse {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .fps-accordion.open .fps-collapse {
    max-height: 400px;
  }

  .fps-collapse-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 24px 20px 8px;
    text-align: center;
  }

  .fps-qr-wrap {
    background: #fff;
    border-radius: 12px;
    padding: 10px;
    border: 1px solid var(--border-subtle);
  }

  .fps-qr-wrap img {
    display: block;
    border-radius: 8px;
  }

  .fps-id-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .fps-label {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 600;
  }

  .fps-number {
    font-family: 'Space Mono', monospace;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .fps-copy {
    padding: 5px 12px;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    background: transparent;
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: var(--accent-electric);
    cursor: pointer;
    transition: all 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .fps-copy:hover {
    background: rgba(15, 110, 86, 0.05);
    border-color: var(--accent-electric);
  }

  .fps-copied {
    font-size: 14px;
    color: var(--accent-electric);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .fps-copied.show {
    opacity: 1;
  }

  .fps-confirm-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: #25D366;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: 13px;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.3s;
    min-height: 44px;
  }

  .fps-confirm-btn:hover {
    background: #1DA851;
    transform: translateY(-1px);
  }

  /* Help */
  .checkout-help {
    text-align: center;
    font-size: 14px;
    color: var(--text-muted);
  }

  .checkout-help a {
    color: var(--accent-electric);
    text-decoration: underline;
    font-weight: 600;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .checkout-page {
      padding: 100px 16px 60px;
    }

    .checkout-header h1 {
      font-size: 28px;
      letter-spacing: -1px;
    }

    .program-tab {
      padding: 16px 12px;
    }

    .tab-name {
      font-size: 13px;
    }

    .age-group {
      padding: 16px;
    }

    .age-group-name {
      font-size: 15px;
    }

    .summary-card {
      padding: 20px;
    }

    .summary-total-amount {
      font-size: 20px;
    }

  }
</style>

<script define:vars={{ STRIPE_LINKS, CAMP_PRICE }}>
  // State
  var state = {
    count: 0,
  };

  // Elements
  var summaryEl = document.getElementById('bookingSummary');
  var summaryLines = document.getElementById('summaryLines');
  var summaryTotal = document.getElementById('summaryTotal');
  var payBtn = document.getElementById('payBtn');
  var payAmountEn = document.getElementById('payAmountEn');
  var payAmountDe = document.getElementById('payAmountDe');
  var emptyHint = document.getElementById('emptyHint');

  // Counter buttons
  document.querySelectorAll('.counter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var isPlus = btn.classList.contains('plus');

      if (isPlus && state.count < 6) {
        state.count++;
      } else if (!isPlus && state.count > 0) {
        state.count--;
      }

      // Update display
      var countEl = document.getElementById('count-camp');
      if (countEl) countEl.textContent = String(state.count);

      // Update button states
      var parent = btn.closest('.counter');
      if (parent) {
        var minus = parent.querySelector('.minus');
        var plus = parent.querySelector('.plus');
        if (minus) minus.disabled = state.count === 0;
        if (plus) plus.disabled = state.count >= 6;
      }

      // Update age-group highlight
      var ageGroup = btn.closest('.age-group');
      if (ageGroup) {
        ageGroup.classList.toggle('has-count', state.count > 0);
      }

      updateSummary();
    });
  });

  function updateSummary() {
    var hasItems = state.count > 0;
    var total = state.count * CAMP_PRICE;

    // Toggle visibility
    if (summaryEl) summaryEl.style.display = hasItems ? 'block' : 'none';
    if (emptyHint) emptyHint.style.display = hasItems ? 'none' : 'block';

    // Build summary lines
    if (summaryLines && hasItems) {
      var labelEn = state.count + '\u00d7 Make Mars Green \u2014 Age 5\u201312';
      var labelDe = state.count + '\u00d7 Make Mars Green \u2014 Alter 5\u201312';
      summaryLines.innerHTML = '<div class="summary-line">' +
        '<span class="summary-line-label"><strong data-lang-en>' + labelEn + '</strong><strong data-lang-de>' + labelDe + '</strong></span>' +
        '<span class="summary-line-price">$' + total.toLocaleString() + ' HKD</span>' +
        '</div>';

      // Re-apply language state
      var isDE = document.body.classList.contains('lang-de');
      summaryLines.querySelectorAll('[data-lang-en]').forEach(function(el) {
        el.style.display = isDE ? 'none' : '';
      });
      summaryLines.querySelectorAll('[data-lang-de]').forEach(function(el) {
        el.style.display = isDE ? '' : 'none';
      });
    }

    // Update total
    var formatted = '$' + total.toLocaleString() + ' HKD';
    if (summaryTotal) summaryTotal.textContent = formatted;
    if (payAmountEn) payAmountEn.textContent = formatted;
    if (payAmountDe) payAmountDe.textContent = formatted;

    // Update pay button link
    if (payBtn && hasItems) {
      var baseLink = STRIPE_LINKS.camp;
      var sep = baseLink.includes('?') ? '&' : '?';
      payBtn.href = baseLink + sep + 'quantity=' + state.count;
    }
  }

  // FPS Accordion toggle
  var fpsToggle = document.getElementById('fpsToggle');
  var fpsAccordion = fpsToggle ? fpsToggle.closest('.fps-accordion') : null;
  if (fpsToggle && fpsAccordion) {
    fpsToggle.addEventListener('click', function() {
      fpsAccordion.classList.toggle('open');
    });
  }

  // FPS Copy
  document.querySelectorAll('#fpsCopyBtn, #fpsCopyBtn2').forEach(function(btn) {
    btn.addEventListener('click', function() {
      navigator.clipboard.writeText('126847250').then(function() {
        var copied = document.getElementById('fpsCopied');
        if (copied) {
          copied.classList.add('show');
          setTimeout(function() { copied.classList.remove('show'); }, 2000);
        }
      });
    });
  });
</script>
