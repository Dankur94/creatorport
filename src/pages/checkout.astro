---
import PageLayout from '../layouts/PageLayout.astro';

const API_BASE = 'https://mail.space-op.com';
const PRODUCT_ID = 'a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d';
---

<PageLayout
  title="Book Now — CreatorPort HK"
  description="Book your child's spot in our AI & Robotics programs. Pay securely with Apple Pay, credit card, or FPS."
>

<section class="checkout-page">
  <div class="container">

    <!-- Header -->
    <div class="checkout-header">
      <h1 data-lang-en>Book a Spot</h1>
      <h1 data-lang-de>Platz buchen</h1>
      <p data-lang-en>Fill in details, pay securely via Stripe.</p>
      <p data-lang-de>Details ausf&uuml;llen, sicher bezahlen via Stripe.</p>
    </div>

    <!-- Step 1: Program Info -->
    <div class="step-section">
      <div class="step-label"><span class="step-num">1</span> <span data-lang-en>Program</span><span data-lang-de>Programm</span></div>
      <div class="program-tab active" id="programTab">
        <span class="tab-name" id="programName">Loading...</span>
        <span class="tab-meta" id="programMeta"></span>
      </div>
    </div>

    <!-- Step 2: Camp Details -->
    <div class="step-section" id="step-details">
      <div class="step-label"><span class="step-num">2</span> <span data-lang-en>Camp Details</span><span data-lang-de>Camp Details</span></div>
      <div class="panel-info" id="programDetails">
        <div class="panel-info-row"><span>loading...</span></div>
      </div>
    </div>

    <!-- Step 3: Child & Parent Info -->
    <div class="step-section">
      <div class="step-label"><span class="step-num">3</span> <span data-lang-en>Your details</span><span data-lang-de>Deine Angaben</span></div>
      <form id="bookingForm" class="booking-form">
        <div class="form-row">
          <div class="form-group">
            <label data-lang-en>Child's Name *</label>
            <label data-lang-de>Name des Kindes *</label>
            <input type="text" id="childName" required placeholder="e.g. Max" />
          </div>
          <div class="form-group form-group-small">
            <label data-lang-en>Age *</label>
            <label data-lang-de>Alter *</label>
            <input type="number" id="childAge" required min="1" max="18" placeholder="8" />
          </div>
        </div>
        <div class="form-group">
          <label data-lang-en>Parent / Guardian Name *</label>
          <label data-lang-de>Elternteil / Vormund Name *</label>
          <input type="text" id="customerName" required placeholder="e.g. John Smith" />
        </div>
        <div class="form-group">
          <label data-lang-en>Email *</label>
          <label data-lang-de>E-Mail *</label>
          <input type="email" id="customerEmail" required placeholder="parent@example.com" />
        </div>
        <div class="form-group">
          <label data-lang-en>Phone (WhatsApp preferred)</label>
          <label data-lang-de>Telefon (WhatsApp bevorzugt)</label>
          <input type="tel" id="customerPhone" placeholder="+852 1234 5678" />
        </div>

        <!-- Error message -->
        <div id="formError" class="form-error" style="display:none;"></div>

        <!-- Pay Button -->
        <button type="submit" class="checkout-pay-btn" id="payBtn">
          <span data-lang-en>Pay <span id="payAmount">...</span> — Apple Pay / Card</span>
          <span data-lang-de><span id="payAmountDe">...</span> bezahlen — Apple Pay / Karte</span>
        </button>
        <div class="summary-trust">
          <span data-lang-en>Secure payment via Stripe &middot; 100% money-back guarantee</span>
          <span data-lang-de>Sichere Zahlung via Stripe &middot; 100% Geld-zur&uuml;ck-Garantie</span>
        </div>
      </form>
    </div>

    <!-- FPS Alternative (collapsible) -->
    <div class="fps-accordion">
      <button class="fps-toggle" id="fpsToggle" type="button">
        <span data-lang-en>Prefer bank transfer? Pay via FPS (no fees)</span>
        <span data-lang-de>Lieber per Bank? Per FPS bezahlen (keine Geb&uuml;hren)</span>
        <span class="fps-chevron">&#9662;</span>
      </button>
      <div class="fps-collapse" id="fpsCollapse">
        <div class="fps-collapse-inner">
          <div class="fps-qr-wrap">
            <img src="/img/fps-qr.jpg" alt="FPS QR Code" width="120" height="120" />
          </div>
          <div class="fps-id-row">
            <span class="fps-label">FPS ID:</span>
            <span class="fps-number">126847250</span>
            <button class="fps-copy" id="fpsCopyBtn" type="button" data-lang-en>Copy</button>
            <button class="fps-copy" id="fpsCopyBtn2" type="button" data-lang-de>Kopieren</button>
            <span class="fps-copied" id="fpsCopied">&#x2713;</span>
          </div>
          <a href="https://wa.me/85265427963?text=Hi%21%20I%27ve%20paid%20via%20FPS.%0A-%20Child%27s%20name%3A%0A-%20Age%3A%0A-%20Program%3A%0A-%20FPS%20reference%3A" target="_blank" class="fps-confirm-btn" data-lang-en>
            Confirm on WhatsApp
          </a>
          <a href="https://wa.me/85265427963?text=Hallo%21%20Ich%20habe%20per%20FPS%20bezahlt.%0A-%20Name%20des%20Kindes%3A%0A-%20Alter%3A%0A-%20Programm%3A%0A-%20FPS-Referenz%3A" target="_blank" class="fps-confirm-btn" data-lang-de>
            Per WhatsApp best&auml;tigen
          </a>
        </div>
      </div>
    </div>

    <!-- Help -->
    <div class="checkout-help">
      <p data-lang-en>Questions? <a href="https://wa.me/85265427963" target="_blank">Chat on WhatsApp</a> or email <a href="mailto:hello@creatorport.com.hk">hello@creatorport.com.hk</a></p>
      <p data-lang-de>Fragen? <a href="https://wa.me/85265427963" target="_blank">Chat auf WhatsApp</a> oder E-Mail an <a href="mailto:hello@creatorport.com.hk">hello@creatorport.com.hk</a></p>
    </div>

  </div>
</section>

</PageLayout>

<style>
  .checkout-page {
    padding: 80px 0 60px;
    min-height: 100vh;
  }

  /* Header */
  .checkout-header {
    text-align: center;
    margin-bottom: 32px;
    padding-top: 16px;
  }

  .checkout-header h1 {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 6px;
  }

  .checkout-header p {
    font-size: 14px;
    color: var(--text-secondary);
  }

  /* Steps */
  .step-section {
    margin-bottom: 24px;
  }

  .step-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .step-num {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Program Tab */
  .program-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 20px;
    background: var(--card-bg);
    border: 2px solid var(--accent);
    border-radius: var(--radius);
    background: rgba(15, 110, 86, 0.04);
  }

  .tab-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }

  .tab-meta {
    font-size: 13px;
    color: var(--text-muted);
  }

  /* Panel Info */
  .panel-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px;
    background: rgba(15, 110, 86, 0.04);
    border: 1px solid rgba(15, 110, 86, 0.1);
    border-radius: var(--radius);
    margin-bottom: 16px;
  }

  .panel-info-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--text-secondary);
  }

  .panel-info-row > span:first-child {
    flex-shrink: 0;
    width: 20px;
    text-align: center;
  }

  /* Booking Form */
  .booking-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-row {
    display: flex;
    gap: 12px;
  }

  .form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .form-group-small {
    flex: 0 0 80px;
  }

  .form-group label {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .form-group input {
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card-bg);
    font-family: 'Sora', sans-serif;
    font-size: 14px;
    color: var(--text);
    transition: border-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .form-group input::placeholder {
    color: var(--text-muted);
  }

  .form-error {
    padding: 12px 16px;
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: var(--radius);
    color: #dc2626;
    font-size: 13px;
    font-weight: 500;
  }

  /* Pay Button */
  .checkout-pay-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 16px 24px;
    border: none;
    border-radius: var(--radius-pill);
    background: var(--accent);
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.2s;
    min-height: 52px;
    -webkit-tap-highlight-color: transparent;
  }

  .checkout-pay-btn:hover:not(:disabled) {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(15, 110, 86, 0.25);
  }

  .checkout-pay-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .summary-trust {
    font-size: 12px;
    color: var(--text-muted);
    text-align: center;
    margin-top: 4px;
  }

  /* FPS Accordion */
  .fps-accordion {
    margin-bottom: 32px;
    margin-top: 8px;
  }

  .fps-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 20px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-family: 'Sora', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .fps-toggle:hover {
    border-color: var(--accent);
    color: var(--text-secondary);
  }

  .fps-chevron {
    font-size: 10px;
    transition: transform 0.3s;
  }

  .fps-accordion.open .fps-chevron {
    transform: rotate(180deg);
  }

  .fps-collapse {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .fps-accordion.open .fps-collapse {
    max-height: 400px;
  }

  .fps-collapse-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 24px 20px 8px;
    text-align: center;
  }

  .fps-qr-wrap {
    background: #fff;
    border-radius: var(--radius);
    padding: 10px;
    border: 1px solid var(--border);
  }

  .fps-qr-wrap img {
    display: block;
    border-radius: 8px;
  }

  .fps-id-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .fps-label {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 600;
  }

  .fps-number {
    font-family: 'Space Mono', monospace;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .fps-copy {
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    cursor: pointer;
    transition: all 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .fps-copy:hover {
    background: rgba(15, 110, 86, 0.05);
    border-color: var(--accent);
  }

  .fps-copied {
    font-size: 14px;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .fps-copied.show {
    opacity: 1;
  }

  .fps-confirm-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: #25D366;
    color: #fff;
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: 13px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: all 0.2s;
    min-height: 44px;
  }

  .fps-confirm-btn:hover {
    background: #1DA851;
  }

  /* Help */
  .checkout-help {
    text-align: center;
    font-size: 14px;
    color: var(--text-muted);
  }

  .checkout-help a {
    color: var(--accent);
    text-decoration: underline;
    font-weight: 600;
  }
</style>

<script define:vars={{ API_BASE, PRODUCT_ID }}>
  // Load product info from API
  fetch(API_BASE + '/api/v1/public/booking/products?account=cp')
    .then(function(r) { return r.json(); })
    .then(function(products) {
      var product = products.find(function(p) { return p.id === PRODUCT_ID; });
      if (!product) return;

      var nameEl = document.getElementById('programName');
      var metaEl = document.getElementById('programMeta');
      var detailsEl = document.getElementById('programDetails');
      var payAmount = document.getElementById('payAmount');
      var payAmountDe = document.getElementById('payAmountDe');

      if (nameEl) nameEl.textContent = product.name;

      var priceStr = '$' + (product.price_cents / 100).toLocaleString() + ' ' + product.currency.toUpperCase();
      if (metaEl) metaEl.textContent = 'Summer Camp \u00b7 ' + priceStr;
      if (payAmount) payAmount.textContent = priceStr;
      if (payAmountDe) payAmountDe.textContent = priceStr;

      if (detailsEl) {
        var startDate = product.start_date || '';
        var endDate = product.end_date || '';
        var location = product.location || '';
        var ageRange = product.age_min + '\u2013' + product.age_max;
        var spots = product.spots_remaining;

        detailsEl.innerHTML =
          '<div class="panel-info-row"><span>\ud83d\udcc5</span><span>' + startDate + ' \u2014 ' + endDate + '</span></div>' +
          '<div class="panel-info-row"><span>\ud83d\udccd</span><span>' + location + '</span></div>' +
          '<div class="panel-info-row"><span>\ud83e\uddd1</span><span>Ages ' + ageRange + '</span></div>' +
          '<div class="panel-info-row"><span>\ud83c\udfab</span><span>' + spots + ' spots remaining</span></div>';
      }
    })
    .catch(function() {
      // Fallback: show static info
      var nameEl = document.getElementById('programName');
      if (nameEl) nameEl.textContent = 'Mission Mars Summer Camp';
    });

  // Form submission
  var form = document.getElementById('bookingForm');
  var payBtn = document.getElementById('payBtn');
  var errorEl = document.getElementById('formError');

  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var childName = document.getElementById('childName').value.trim();
      var childAge = parseInt(document.getElementById('childAge').value, 10);
      var customerName = document.getElementById('customerName').value.trim();
      var customerEmail = document.getElementById('customerEmail').value.trim();
      var customerPhone = (document.getElementById('customerPhone').value || '').trim();

      if (!childName || !childAge || !customerName || !customerEmail) {
        showError('Please fill in all required fields.');
        return;
      }

      // Disable button, show loading
      payBtn.disabled = true;
      payBtn.innerHTML = '<span>Processing...</span>';

      // Collect UTM params from URL
      var params = new URLSearchParams(window.location.search);

      var body = {
        product_id: PRODUCT_ID,
        child_name: childName,
        child_age: childAge,
        customer_name: customerName,
        customer_email: customerEmail,
        customer_phone: customerPhone,
        success_url: 'https://creatorport.com.hk/success',
        cancel_url: 'https://creatorport.com.hk/checkout',
        gclid: params.get('gclid') || '',
        utm_source: params.get('utm_source') || '',
        utm_campaign: params.get('utm_campaign') || '',
      };

      fetch(API_BASE + '/api/v1/public/booking/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      })
        .then(function(r) {
          if (!r.ok) return r.json().then(function(d) { throw new Error(d.detail || 'Booking failed'); });
          return r.json();
        })
        .then(function(data) {
          if (data.checkout_url) {
            window.location.href = data.checkout_url;
          } else {
            throw new Error('No checkout URL returned');
          }
        })
        .catch(function(err) {
          showError(err.message || 'Something went wrong. Please try again.');
          payBtn.disabled = false;
          var isDE = document.body.classList.contains('lang-de');
          payBtn.innerHTML = isDE
            ? '<span data-lang-de>Bezahlen — Apple Pay / Karte</span>'
            : '<span data-lang-en>Pay — Apple Pay / Card</span>';
        });
    });
  }

  function showError(msg) {
    if (errorEl) {
      errorEl.textContent = msg;
      errorEl.style.display = 'block';
      setTimeout(function() { errorEl.style.display = 'none'; }, 8000);
    }
  }

  // FPS Accordion toggle
  var fpsToggle = document.getElementById('fpsToggle');
  var fpsAccordion = fpsToggle ? fpsToggle.closest('.fps-accordion') : null;
  if (fpsToggle && fpsAccordion) {
    fpsToggle.addEventListener('click', function() {
      fpsAccordion.classList.toggle('open');
    });
  }

  // FPS Copy
  document.querySelectorAll('#fpsCopyBtn, #fpsCopyBtn2').forEach(function(btn) {
    btn.addEventListener('click', function() {
      navigator.clipboard.writeText('126847250').then(function() {
        var copied = document.getElementById('fpsCopied');
        if (copied) {
          copied.classList.add('show');
          setTimeout(function() { copied.classList.remove('show'); }, 2000);
        }
      });
    });
  });
</script>
