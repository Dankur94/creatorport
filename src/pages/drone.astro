---
import PageLayout from '../layouts/PageLayout.astro';

const navLinks = [{ href: '/adults', en: '\u2190 All Workshops', de: '\u2190 Alle Workshops' }];
---

<PageLayout
  title="CreatorPort HK — Build a Gripper Drone Workshop"
  description="Build a real indoor drone with a mechanical gripper arm. 4-hour group workshop. $150 USD/person."
  navLinks={navLinks}
  navCta={{ href: 'https://wa.me/85265427963?text=%23drone', en: 'Book Now', de: 'Jetzt buchen' }}
  navAccent="electric"
  footerExtra={'Kit by <a href="https://kurthtechnik.de" target="_blank" style="color: var(--accent-electric);">KurthTechnik</a>'}
>
  <!-- HERO -->
  <div class="hero">
    <div class="hero-badge reveal" data-lang-en>Group Experience &middot; 4 Hours &middot; Tsuen Wan, Riviera Gardens</div>
    <div class="hero-badge reveal" data-lang-de>Gruppenerlebnis &middot; 4 Stunden &middot; Tsuen Wan, Riviera Gardens</div>
    <div class="hero-tag reveal" data-lang-en>Workshop #03 &middot; DIY Robotics &middot; Drone Engineering</div>
    <div class="hero-tag reveal" data-lang-de>Workshop #03 &middot; DIY-Robotik &middot; Drohnen-Engineering</div>
    <h1 class="reveal" data-lang-en>Build a<br><span class="gradient-text">Gripper Drone</span></h1>
    <h1 class="reveal" data-lang-de>Baue eine<br><span class="gradient-text">Greifer-Drohne</span></h1>
    <p class="hero-sub reveal" data-lang-en>Build a real indoor drone with a mechanical gripper arm &mdash; fly it, grab objects, and take it home.</p>
    <p class="hero-sub reveal" data-lang-de>Baue eine echte Indoor-Drohne mit mechanischem Greifarm &mdash; fliege sie, greife Objekte und nimm sie mit nach Hause.</p>
    <div class="hero-actions reveal" data-lang-en>
      <a href="https://wa.me/85265427963?text=%23drone" target="_blank" class="btn-primary">Book Drone Workshop &rarr;</a>
      <a href="https://kurthtechnik.de" target="_blank" class="btn-secondary">About KurthTechnik Kits</a>
    </div>
    <div class="hero-actions reveal" data-lang-de>
      <a href="https://wa.me/85265427963?text=%23drone" target="_blank" class="btn-primary">Drohnen-Workshop buchen &rarr;</a>
      <a href="https://kurthtechnik.de" target="_blank" class="btn-secondary">&Uuml;ber KurthTechnik Baus&auml;tze</a>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="content">
    <!-- Detail Card 1 -->
    <div class="detail-card reveal">
      <h2 data-lang-en>What you&rsquo;ll build</h2>
      <h2 data-lang-de>Was du baust</h2>
      <ul class="detail-list">
        <li data-lang-en>Indoor drone frame with brushless motors and propellers</li>
        <li data-lang-de>Indoor-Drohnenrahmen mit b&uuml;rstenlosen Motoren und Propellern</li>
        <li data-lang-en>Mechanical gripper arm &mdash; servo-controlled for object pickup</li>
        <li data-lang-de>Mechanischer Greifarm &mdash; servogesteuert zum Greifen von Objekten</li>
        <li data-lang-en>Flight controller setup and calibration</li>
        <li data-lang-de>Flugcontroller-Setup und Kalibrierung</li>
        <li data-lang-en>Radio transmitter binding and trim configuration</li>
        <li data-lang-de>Funksender-Bindung und Trimmkonfiguration</li>
        <li data-lang-en>Test flight and gripper challenge at the end</li>
        <li data-lang-de>Testflug und Greifer-Challenge am Ende</li>
      </ul>
    </div>

    <!-- Detail Card 2 -->
    <div class="detail-card reveal">
      <h2 data-lang-en>Workshop details</h2>
      <h2 data-lang-de>Workshop-Details</h2>
      <ul class="detail-list">
        <li data-lang-en>Duration: ~4 hours</li>
        <li data-lang-de>Dauer: ~4 Stunden</li>
        <li data-lang-en>Group size: max 6 people</li>
        <li data-lang-de>Gruppengr&ouml;&szlig;e: max. 6 Personen</li>
        <li data-lang-en>Flexible scheduling &mdash; book a date that works for your group</li>
        <li data-lang-de>Flexible Terminplanung &mdash; buche ein Datum, das f&uuml;r deine Gruppe passt</li>
        <li data-lang-en>You take the drone home &mdash; kit is included in the price</li>
        <li data-lang-de>Du nimmst die Drohne mit &mdash; Bausatz ist im Preis enthalten</li>
        <li data-lang-en>Location: Tsuen Wan, Riviera Gardens</li>
        <li data-lang-de>Ort: Tsuen Wan, Riviera Gardens</li>
      </ul>
    </div>

    <!-- Price Box -->
    <div class="price-box reveal">
      <div class="price-big">$150 <span>USD / person</span></div>
      <p class="price-note" data-lang-en>Drone kit included. You build it, you fly it, you keep it.</p>
      <p class="price-note" data-lang-de>Drohnen-Bausatz inklusive. Du baust sie, fliegst sie, beh&auml;ltst sie.</p>
    </div>

    <!-- Kit Box -->
    <div class="kit-box reveal">
      <p data-lang-en>Want to explore more KurthTechnik kits?</p>
      <p data-lang-de>Mehr KurthTechnik Baus&auml;tze entdecken?</p>
      <a href="https://kurthtechnik.de" target="_blank" data-lang-en>Visit KurthTechnik &rarr;</a>
      <a href="https://kurthtechnik.de" target="_blank" data-lang-de>KurthTechnik besuchen &rarr;</a>
    </div>
  </div>
</PageLayout>

<style is:global>
  @import '../styles/components.css';
</style>

<style>
  .hero {
    min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center; padding: 120px 40px 80px; position: relative;
  }
  .hero-tag { font-size: 14px; text-transform: uppercase; letter-spacing: 3px; font-weight: 600; margin-bottom: 24px; color: var(--accent-electric); }
  .hero h1 { font-size: 64px; font-weight: 800; letter-spacing: -3px; line-height: 1.05; margin-bottom: 24px; max-width: 800px; }
  .hero-sub { font-size: 20px; color: var(--text-secondary); max-width: 600px; line-height: 1.7; margin-bottom: 40px; }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
  .btn-secondary { padding: 16px 36px; border-radius: 30px; font-weight: 600; font-size: 16px; text-decoration: none; color: var(--text-primary); border: 1px solid var(--border-subtle); background: transparent; transition: all 0.3s; }
  .btn-secondary:hover { border-color: var(--accent-electric); color: var(--accent-electric); }
  .content { max-width: 700px; margin: 0 auto; padding: 0 40px 100px; }
  .price-box { text-align: center; padding: 32px; border-radius: 20px; margin-bottom: 32px; background: linear-gradient(135deg, rgba(15,110,86,0.08), rgba(15,110,86,0.03)); }
  .price-big { font-size: 48px; font-weight: 800; color: var(--accent-electric); }
  .price-big span { font-size: 16px; font-weight: 400; color: var(--text-muted); }
  .price-note { font-size: 14px; color: var(--text-muted); margin-top: 8px; }
  .kit-box { margin-top: 32px; padding: 24px; border-radius: 16px; text-align: center; background: rgba(15,110,86,0.04); border: 1px solid rgba(15,110,86,0.15); }
  .kit-box p { font-size: 14px; color: var(--text-secondary); margin-bottom: 8px; }
  .kit-box a { text-decoration: underline; font-weight: 600; color: var(--accent-electric); }

  .hero-badge {
    background: rgba(15, 110, 86, 0.08);
    border-color: rgba(15, 110, 86, 0.2);
    color: var(--accent-electric);
  }
  .hero-badge::before { background: var(--accent-electric); }

  .detail-card { border: 1px solid rgba(15, 110, 86, 0.15); }
  .detail-list li::before { color: var(--accent-electric); }

  @media (max-width: 768px) {
    .hero { padding: 100px 24px 60px; min-height: auto; }
    .hero h1 { font-size: 36px; letter-spacing: -1.5px; }
    .hero-sub { font-size: 16px; }
    .hero-actions { flex-direction: column; }
    .btn-primary, .btn-secondary { width: 100%; text-align: center; justify-content: center; }
    .content { padding: 0 24px 80px; }
  }
  @media (max-width: 1024px) and (min-width: 769px) {
    .hero h1 { font-size: 52px; }
  }
</style>
