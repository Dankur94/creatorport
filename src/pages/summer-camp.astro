<script define:vars={{ waNumber }}>
  // Form → WhatsApp
  document.getElementById('campForm')?.addEventListener('submit', function(e) {
    e.preventDefault();

    const parentName = document.getElementById('parentName').value.trim();
    const childName = document.getElementById('childName').value.trim();
    const childAge = document.getElementById('childAge').value.trim();
    const lang = document.getElementById('lang').value;
    const notes = document.getElementById('notes').value.trim();

    if (!parentName || !childName || !childAge || !lang) return;

    let msg = `Hi! I'd like to reserve a spot for the Summer Camp 2026.\n`;
    msg += `- Parent: ${parentName}\n`;
    msg += `- Child: ${childName}\n`;
    msg += `- Age: ${childAge}\n`;
    msg += `- Language: ${lang}\n`;
    if (notes) msg += `- Notes: ${notes}\n`;

    const url = `https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}`;
    window.open(url, '_blank');
  });

  // Floating spots counter — show after scrolling past hero
  const spotsFloat = document.getElementById('spotsFloat');
  const heroEl = document.querySelector('.sc-hero');
  if (spotsFloat && heroEl) {
    const obs = new IntersectionObserver(([entry]) => {
      spotsFloat.classList.toggle('visible', !entry.isIntersecting);
    }, { threshold: 0 });
    obs.observe(heroEl);
  }
</script>
