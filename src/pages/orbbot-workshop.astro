---
import PageLayout from '../layouts/PageLayout.astro';

const navLinks = [{ href: '/adults', en: '\u2190 All Workshops', de: '\u2190 Alle Workshops' }];
---

<PageLayout
  title="CreatorPort HK — Build an OrbBot Workshop"
  description="Build a self-balancing robot that stays upright on a ball. Advanced robotics workshop in Hong Kong."
  navLinks={navLinks}
  navCta={{ href: 'https://wa.me/85265427963?text=%23orbbot', en: 'Book Now', de: 'Jetzt buchen' }}
  navAccent="electric"
  footerExtra={'Kit by <a href="https://kurthtechnik.de" target="_blank" style="color: var(--accent-electric);">KurthTechnik</a>'}
>
  <!-- HERO -->
  <div class="hero">
    <div class="coming-soon-badge reveal" data-lang-en>Coming Soon</div>
    <div class="coming-soon-badge reveal" data-lang-de>Demnächst</div>
    <div class="hero-tag reveal" data-lang-en>Workshop #04 &middot; Advanced Robotics &middot; Engineering Challenge</div>
    <div class="hero-tag reveal" data-lang-de>Workshop #04 &middot; Fortgeschrittene Robotik &middot; Engineering-Challenge</div>
    <h1 class="reveal" data-lang-en>Build an<br><span class="gradient-text">OrbBot</span></h1>
    <h1 class="reveal" data-lang-de>Baue einen<br><span class="gradient-text">OrbBot</span></h1>
    <p class="hero-sub reveal" data-lang-en>A self-balancing robot that stays upright on a ball &mdash; the most advanced hands-on robotics workshop we offer.</p>
    <p class="hero-sub reveal" data-lang-de>Ein selbstbalancierender Roboter, der auf einer Kugel aufrecht bleibt &mdash; unser anspruchsvollster Hands-on-Robotik-Workshop.</p>
  </div>

  <!-- CONTENT -->
  <div class="content">
    <!-- Detail Card 1 -->
    <div class="detail-card reveal">
      <h2 data-lang-en>What you&rsquo;ll build</h2>
      <h2 data-lang-de>Was du baust</h2>
      <ul class="detail-list">
        <li data-lang-en>Self-balancing robot that balances on a single ball</li>
        <li data-lang-de>Selbstbalancierender Roboter, der auf einer einzelnen Kugel balanciert</li>
        <li data-lang-en>3-axis control system with omniwheels</li>
        <li data-lang-de>3-Achsen-Steuerungssystem mit Omniwheels</li>
        <li data-lang-en>IMU sensors (accelerometer + gyroscope) for real-time balance</li>
        <li data-lang-de>IMU-Sensoren (Beschleunigungsmesser + Gyroskop) f&uuml;r Echtzeit-Balance</li>
        <li data-lang-en>PID control loops &mdash; tune the system until it balances on its own</li>
        <li data-lang-de>PID-Regelkreise &mdash; stimme das System ab, bis es sich selbst balanciert</li>
        <li data-lang-en>You take the OrbBot home after the workshop</li>
        <li data-lang-de>Du nimmst den OrbBot nach dem Workshop mit nach Hause</li>
      </ul>
    </div>

    <!-- Detail Card 2 -->
    <div class="detail-card reveal">
      <h2 data-lang-en>Workshop details</h2>
      <h2 data-lang-de>Workshop-Details</h2>
      <ul class="detail-list">
        <li data-lang-en>Duration: ~4 hours</li>
        <li data-lang-de>Dauer: ~4 Stunden</li>
        <li data-lang-en>Group size: max 6 people</li>
        <li data-lang-de>Gruppengr&ouml;&szlig;e: max. 6 Personen</li>
        <li data-lang-en>Advanced level &mdash; no prior robotics experience required, but curiosity is a must</li>
        <li data-lang-de>Fortgeschrittenes Level &mdash; keine Robotik-Erfahrung n&ouml;tig, aber Neugierde ist Pflicht</li>
        <li data-lang-en>You take the OrbBot home &mdash; keep building and experimenting</li>
        <li data-lang-de>Du nimmst den OrbBot mit &mdash; baue und experimentiere weiter</li>
        <li data-lang-en>Location: Tsuen Wan, Riviera Gardens</li>
        <li data-lang-de>Ort: Tsuen Wan, Riviera Gardens</li>
      </ul>
    </div>

    <!-- Highlight Box (Coming Soon) -->
    <div class="highlight-box reveal">
      <p data-lang-en>This workshop is currently being finalised.</p>
      <p data-lang-de>Dieser Workshop wird gerade fertiggestellt.</p>
      <p data-lang-en style="font-weight: 400; color: var(--text-secondary); font-size: 14px;">Interested? Send <strong style="color: var(--accent-electric);">#orbbot</strong> on WhatsApp and we&rsquo;ll notify you when it&rsquo;s ready.</p>
      <p data-lang-de style="font-weight: 400; color: var(--text-secondary); font-size: 14px;">Interessiert? Sende <strong style="color: var(--accent-electric);">#orbbot</strong> per WhatsApp und wir benachrichtigen dich, wenn es soweit ist.</p>
      <a href="https://wa.me/85265427963?text=%23orbbot" target="_blank" class="btn-secondary" style="margin-top: 16px; display: inline-block;" data-lang-en>Send #orbbot &rarr;</a>
      <a href="https://wa.me/85265427963?text=%23orbbot" target="_blank" class="btn-secondary" style="margin-top: 16px; display: inline-block;" data-lang-de>#orbbot senden &rarr;</a>
    </div>

    <!-- Upsell Box -->
    <div class="kit-box reveal">
      <p data-lang-en>Want to keep building at home?</p>
      <p data-lang-de>Willst du zu Hause weiterbauen?</p>
      <a href="https://kurthtechnik.de" target="_blank" data-lang-en>Explore KurthTechnik Kits &rarr;</a>
      <a href="https://kurthtechnik.de" target="_blank" data-lang-de>KurthTechnik Baus&auml;tze entdecken &rarr;</a>
    </div>
  </div>
</PageLayout>

<style is:global>
  @import '../styles/components.css';
</style>

<style>
  .hero {
    min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center; padding: 120px 40px 80px; position: relative;
  }
  .hero-tag { font-size: 14px; text-transform: uppercase; letter-spacing: 3px; font-weight: 600; margin-bottom: 24px; color: var(--accent-electric); }
  .hero h1 { font-size: 64px; font-weight: 800; letter-spacing: -3px; line-height: 1.05; margin-bottom: 24px; max-width: 800px; }
  .hero-sub { font-size: 20px; color: var(--text-secondary); max-width: 600px; line-height: 1.7; margin-bottom: 40px; }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
  .btn-secondary { padding: 16px 36px; border-radius: 30px; font-weight: 600; font-size: 16px; text-decoration: none; color: var(--text-primary); border: 1px solid var(--border-subtle); background: transparent; transition: all 0.3s; }
  .btn-secondary:hover { border-color: var(--accent-electric); color: var(--accent-electric); }
  .content { max-width: 700px; margin: 0 auto; padding: 0 40px 100px; }
  .kit-box { margin-top: 32px; padding: 24px; border-radius: 16px; text-align: center; background: rgba(15,110,86,0.04); border: 1px solid rgba(15,110,86,0.15); }
  .kit-box p { font-size: 14px; color: var(--text-secondary); margin-bottom: 8px; }
  .kit-box a { text-decoration: underline; font-weight: 600; color: var(--accent-electric); }

  .coming-soon-badge {
    background: rgba(15, 110, 86, 0.08);
    border: 1px dashed rgba(15, 110, 86, 0.4);
    color: var(--accent-electric);
  }

  .detail-card { border: 1px solid rgba(15, 110, 86, 0.15); }
  .detail-list li::before { color: var(--accent-electric); }

  .highlight-box {
    background: rgba(15, 110, 86, 0.06);
    border: 1px dashed rgba(15, 110, 86, 0.3);
  }
  .highlight-box p { color: var(--accent-electric); }

  @media (max-width: 768px) {
    .hero { padding: 100px 24px 60px; min-height: auto; }
    .hero h1 { font-size: 36px; letter-spacing: -1.5px; }
    .hero-sub { font-size: 16px; }
    .hero-actions { flex-direction: column; }
    .btn-primary, .btn-secondary { width: 100%; text-align: center; justify-content: center; }
    .content { padding: 0 24px 80px; }
  }
  @media (max-width: 1024px) and (min-width: 769px) {
    .hero h1 { font-size: 52px; }
  }
</style>
