---
import PageLayout from '../layouts/PageLayout.astro';

const whatsappEn = "https://wa.me/85265427963?text=Hi%21%20I%27m%20inquiring%20about%20CreatorPort HK%20for%20our%20institution.%0A-%20Organisation%3A%0A-%20Type%20%28School%20/%20University%20/%20Other%29%3A%0A-%20Number%20of%20students%3A%0A-%20What%20we%27re%20looking%20for%3A%0A%0ACreatorPort HK%20%28brand%20operated%20by%20%C2%A9%20Space%20of%20Possibilities%20Limited%29";
const whatsappDe = "https://wa.me/85265427963?text=Hallo%21%20Ich%20interessiere%20mich%20f%C3%BCr%20CreatorPort HK%20f%C3%BCr%20unsere%20Institution.%0A-%20Organisation%3A%0A-%20Typ%20%28Schule%20/%20Universit%C3%A4t%20/%20Andere%29%3A%0A-%20Anzahl%20der%20Sch%C3%BCler%3A%0A-%20Was%20wir%20suchen%3A%0A%0ACreatorPort HK%20%28brand%20operated%20by%20%C2%A9%20Space%20of%20Possibilities%20Limited%29";
---

<PageLayout
  title="CreatorPort HK for Institutions — AI & Robotics Workshops for Schools & Universities"
  description="Bring AI and robotics education to your school, university, or organisation. German-engineered workshops led by an RWTH Aachen University engineer."
  navAccent="electric"
  footerExtra=""
>
  <!-- HERO -->
  <div class="hero">
    <div class="hero-label" data-lang-en>For Schools &middot; Universities &middot; Organisations</div>
    <div class="hero-label" data-lang-de>F&uuml;r Schulen &middot; Universit&auml;ten &middot; Organisationen</div>
    <h1 data-lang-en>Bring robotics &amp; AI into your classroom.</h1>
    <h1 data-lang-de>Bringen Sie Robotik &amp; KI in Ihr Klassenzimmer.</h1>
    <p class="hero-sub" data-lang-en>Hands-on workshops led by an RWTH Aachen University engineer. On-site at your institution or at our studio on Hong Kong Island.</p>
    <p class="hero-sub" data-lang-de>Praxisnahe Workshops geleitet von einem Ingenieur der RWTH Aachen. Vor Ort in Ihrer Institution oder in unserem Studio auf Hong Kong Island.</p>
    <div class="hero-actions" data-lang-en>
      <a href="#contact" class="btn-dark">Request a Proposal</a>
      <a href="#formats" class="btn-outline">Learn More</a>
    </div>
    <div class="hero-actions" data-lang-de>
      <a href="#contact" class="btn-dark">Angebot anfordern</a>
      <a href="#formats" class="btn-outline">Mehr erfahren</a>
    </div>
  </div>

  <!-- INSTRUCTOR TRUST BAR -->
  <div class="trust" data-lang-en>
    <div class="trust-item"><strong>Daniel Kurth</strong> &mdash; Founder &amp; Lead Instructor</div>
    <div class="trust-item"><strong>B.Sc.RWTH</strong> Aachen</div>
    <div class="trust-item">Mechanical Eng. &middot; Business &middot; Manufacturing</div>
    <div class="trust-item"><strong>Bilingual</strong> EN / DE</div>
  </div>
  <div class="trust" data-lang-de>
    <div class="trust-item"><strong>Daniel Kurth</strong> &mdash; Gr&uuml;nder &amp; Kursleiter</div>
    <div class="trust-item"><strong>B.Sc.RWTH</strong> Aachen</div>
    <div class="trust-item">Maschinenbau &middot; BWL &middot; Fertigungstechnik</div>
    <div class="trust-item"><strong>Zweisprachig</strong> EN / DE</div>
  </div>

  <!-- FORMATS -->
  <section id="formats" class="formats-section">
    <div class="section-label" data-lang-en>Delivery Formats</div>
    <div class="section-label" data-lang-de>Durchf&uuml;hrungsformate</div>
    <h2 class="section-title" data-lang-en>Flexible to fit your schedule.</h2>
    <h2 class="section-title" data-lang-de>Flexibel anpassbar an Ihren Zeitplan.</h2>
    <p class="section-desc" data-lang-en>We come to you, or you come to us. All workshops delivered in English or German.</p>
    <p class="section-desc" data-lang-de>Wir kommen zu Ihnen oder Sie kommen zu uns. Alle Workshops auf Englisch oder Deutsch.</p>

    <div class="formats" data-lang-en>
      <div class="format-card">
        <div class="format-num">01</div>
        <h3 class="format-title">On-Site at Your Institution</h3>
        <p class="format-desc">We bring everything to your school &mdash; iPads, micro:bits, tools, and all materials. All we need is a classroom with tables and power. Minimum 6 students.</p>
      </div>
      <div class="format-card">
        <div class="format-num">02</div>
        <h3 class="format-title">At Our Studio</h3>
        <p class="format-desc">Bring your students to our fully equipped makerspace on Hong Kong Island. Ideal for field trips and enrichment days. Max 12 students per session.</p>
      </div>
      <div class="format-card">
        <div class="format-num">03</div>
        <h3 class="format-title">In-House Teaching</h3>
        <p class="format-desc">Embed our instructor into your school for a term or full year. We teach robotics and AI as part of your regular curriculum, using your classrooms and schedule.</p>
      </div>
      <div class="format-card">
        <div class="format-num">04</div>
        <h3 class="format-title">Multi-Session Program</h3>
        <p class="format-desc">Co-design a syllabus with your teachers over weeks or a full term. Weekly sessions, assessed projects, progress reports.</p>
      </div>
    </div>

    <div class="formats" data-lang-de>
      <div class="format-card">
        <div class="format-num">01</div>
        <h3 class="format-title">Vor Ort in Ihrer Institution</h3>
        <p class="format-desc">Wir bringen alles mit &mdash; iPads, micro:bits, Werkzeuge und alle Materialien. Wir brauchen nur einen Raum mit Tischen und Strom. Mindestens 6 Sch&uuml;ler.</p>
      </div>
      <div class="format-card">
        <div class="format-num">02</div>
        <h3 class="format-title">In unserem Studio</h3>
        <p class="format-desc">Bringen Sie Ihre Sch&uuml;ler in unseren voll ausgestatteten Makerspace auf Hong Kong Island. Ideal f&uuml;r Exkursionen und Projekttage. Max. 12 Sch&uuml;ler pro Sitzung.</p>
      </div>
      <div class="format-card">
        <div class="format-num">03</div>
        <h3 class="format-title">Integrierter Unterricht</h3>
        <p class="format-desc">Integrieren Sie unseren Kursleiter f&uuml;r ein Semester oder ein ganzes Jahr. Wir unterrichten Robotik und KI als Teil Ihres regul&auml;ren Lehrplans, in Ihren R&auml;umen und nach Ihrem Zeitplan.</p>
      </div>
      <div class="format-card">
        <div class="format-num">04</div>
        <h3 class="format-title">Mehrteiliges Programm</h3>
        <p class="format-desc">Gestalten Sie gemeinsam mit Ihren Lehrkr&auml;ften einen Lehrplan &uuml;ber Wochen oder ein ganzes Semester. W&ouml;chentliche Sitzungen, bewertete Projekte, Fortschrittsberichte.</p>
      </div>
    </div>

    <div class="formats-note" data-lang-en>
      <p class="formats-note-sub">All workshops and programs delivered in</p>
      <p class="formats-note-main">English or German</p>
    </div>
    <div class="formats-note" data-lang-de>
      <p class="formats-note-sub">Alle Workshops und Programme verf&uuml;gbar auf</p>
      <p class="formats-note-main">Englisch oder Deutsch</p>
    </div>
  </section>

  <!-- CONTACT CTA BANNER -->
  <div class="cta-banner" id="contact">
    <h2 data-lang-en>Let's design a program for your students.</h2>
    <h2 data-lang-de>Lassen Sie uns ein Programm f&uuml;r Ihre Sch&uuml;ler gestalten.</h2>
    <p data-lang-en>Tell us about your institution and we'll create a tailored proposal &mdash; format, group size, pricing, and schedule.</p>
    <p data-lang-de>Erz&auml;hlen Sie uns von Ihrer Institution und wir erstellen ein ma&szlig;geschneidertes Angebot &mdash; Format, Gruppengr&ouml;&szlig;e, Preise und Zeitplan.</p>
    <div class="cta-actions">
      <a href="mailto:hello@creatorport.com.hk" class="btn-white" data-lang-en>hello@creatorport.com.hk</a>
      <a href="mailto:hello@creatorport.com.hk" class="btn-white" data-lang-de>hello@creatorport.com.hk</a>
      <a href={whatsappEn} target="_blank" class="btn-white-outline" data-lang-en>WhatsApp</a>
      <a href={whatsappDe} target="_blank" class="btn-white-outline" data-lang-de>WhatsApp</a>
    </div>
  </div>
</PageLayout>

<style is:global>
  @import '../styles/components.css';

  /* Layout-preserving overrides for institutions page */
  body.lang-de .trust[data-lang-de] { display: flex !important; }
  body.lang-de .formats[data-lang-de] { display: grid !important; }
  body.lang-de li[data-lang-de] { display: flex !important; }

</style>

<style>
  /* HERO */
  .hero {
    padding: 140px 60px 80px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-label {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent-electric);
    font-weight: 600;
    margin-bottom: 16px;
  }

  .hero h1 {
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -2px;
    line-height: 1.1;
    margin-bottom: 20px;
    max-width: 700px;
  }

  .hero-sub {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-dark {
    padding: 14px 32px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    color: #fff;
    background: #D85A30;
    transition: all 0.3s;
    display: inline-block;
  }

  .btn-dark:hover {
    background: #C04A22;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(216,90,48,0.2);
  }

  .btn-outline {
    padding: 14px 32px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    color: var(--text-primary);
    background: transparent;
    border: 1px solid var(--border-subtle);
    transition: all 0.3s;
    display: inline-block;
  }

  .btn-outline:hover {
    border-color: var(--accent-electric);
  }

  /* TRUST BAR */
  .trust {
    padding: 40px 60px;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    gap: 48px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .trust-item {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .trust-item strong {
    color: var(--text-primary);
    font-weight: 700;
  }

  /* FORMATS SECTION */
  .formats-section {
    padding: 80px 60px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .formats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .format-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 32px;
    transition: all 0.3s;
  }

  .format-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    transform: translateY(-3px);
  }

  .format-num {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    color: var(--accent-electric);
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .format-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .format-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .formats-note {
    text-align: center;
    margin-top: 40px;
    padding: 24px;
    background: #f5f5fa;
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
  }

  .formats-note-sub {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 4px;
  }

  .formats-note-main {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
  }

  .formats-note-credit {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .formats-note-credit a {
    color: var(--accent-electric);
    text-decoration: none;
    font-weight: 600;
  }

  /* CTA BANNER */
  .cta-banner {
    background: var(--accent-electric);
    color: #fff;
    border-radius: 16px;
    padding: 60px;
    text-align: center;
    margin: 40px 60px 0;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-banner h2 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 12px;
    letter-spacing: -1px;
    color: #fff;
  }

  .cta-banner p {
    font-size: 16px;
    opacity: 0.8;
    margin-bottom: 28px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    color: #fff;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-white {
    padding: 14px 32px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    color: var(--accent-electric);
    background: var(--bg-primary);
    transition: all 0.3s;
    display: inline-block;
  }

  .btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  .btn-white-outline {
    padding: 14px 32px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    color: #fff;
    background: transparent;
    border: 1px solid rgba(44,44,42,0.15);
    transition: all 0.3s;
    display: inline-block;
  }

  .btn-white-outline:hover {
    border-color: #fff;
    transform: translateY(-2px);
  }

  /* RESPONSIVE — MOBILE */
  @media (max-width: 768px) {
    .hero {
      padding: 110px 24px 60px;
    }

    .hero h1 {
      font-size: 32px;
    }

    .hero-sub {
      font-size: 16px;
    }

    .trust {
      padding: 24px;
      gap: 24px;
    }

    .formats-section {
      padding: 60px 24px;
    }

    .formats {
      grid-template-columns: 1fr;
    }

    body.lang-de .formats[data-lang-de] {
      grid-template-columns: 1fr !important;
    }

    .cta-banner {
      margin: 40px 24px 0;
      padding: 40px 24px;
    }

    .cta-banner h2 {
      font-size: 24px;
    }

    .cta-actions {
      flex-direction: column;
      align-items: center;
    }

    .format-desc {
      font-size: 14px;
    }

    .formats-note-credit {
      font-size: 14px;
    }
  }

  /* RESPONSIVE — TABLET */
  @media (max-width: 1024px) and (min-width: 769px) {
    .hero h1 {
      font-size: 42px;
    }

    .formats {
      grid-template-columns: repeat(2, 1fr);
    }

  }
</style>
