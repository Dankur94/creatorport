  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --sweep-wall: #F3F1ED;
      --sweep-floor: #E1DCD4;
      --horizon: #ECE8E1;
      --ink: #181310;
      --ink-soft: #7A736A;
      --ink-faint: #B7AFA4;
      --line: #D6D0C6;
      --page-bg: #FBFAF8;
    }

    /* Body doesn't scroll → no pull-to-refresh */
    html, body {
      height: 100%;
      overflow: hidden;
    }

    body {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      background: #FFFFFF;
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
    }

    /* All scrolling happens here */
    .scroll-root {
      height: 100dvh;
      overflow-y: auto;
      overscroll-behavior-y: none;
      -webkit-overflow-scrolling: touch;
    }

    /* ── Card wrappers ── */
    .card-wrap {
      height: 200dvh;
    }

    .card-wrap:first-child {
      height: 100dvh;
    }

    /* Last card keeps 200dvh default — margin eats 100dvh,
       remaining 100dvh ensures card is reachable */

    .card-wrap + .card-wrap {
      margin-top: -100dvh;
    }

    /* Descending z-index: Card 1 on top, peels to reveal Card 2, etc. */
    .card-wrap:nth-child(1) .card { z-index: 5; }
    .card-wrap:nth-child(2) .card { z-index: 4; }
    .card-wrap:nth-child(3) .card { z-index: 3; }
    .card-wrap:nth-child(4) .card { z-index: 2; }
    .card-wrap:nth-child(5) .card { z-index: 1; }

    /* ── Card ── */
    .card {
      position: sticky;
      top: 0;
      height: 100dvh;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 6vh 24px;
      gap: 22px;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
      overflow: hidden;
    }

    .card-label {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .32em;
      color: var(--ink-soft);
    }

    .card-title {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(2.6rem, 8vw, 5.2rem);
      font-weight: 600;
      line-height: .98;
      letter-spacing: -.02em;
      color: var(--ink);
      max-width: 14ch;
    }

    .card-hero-title {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-weight: 900;
      text-transform: uppercase;
      white-space: nowrap;
      font-size: 5.8vw;
      line-height: 1;
      letter-spacing: .32em;
      color: var(--ink);
      border: 2px solid var(--ink);
      padding: .4em .5em;
    }

    .card-text {
      max-width: 38ch;
      color: var(--ink-soft);
      font-size: clamp(1rem, 2.4vw, 1.15rem);
      line-height: 1.55;
    }

    .card-hero-img {
      position: absolute;
      left: -5%;
      bottom: -5%;
      height: 33%;
      width: auto;
      pointer-events: none;
    }

    @media (min-width: 768px) {
      .card-hero-img {
        height: 55%;
      }
    }

    .c1-banner {
      position: absolute;
      bottom: clamp(80px, 16vw, 160px);
      right: clamp(16px, 4vw, 32px);
      background: #fff;
      color: var(--ink);
      padding: clamp(16px, 3vw, 28px) clamp(20px, 4vw, 36px);
      border-radius: 20px;
      z-index: 2;
      text-align: center;
      max-width: 300px;
      box-shadow: 0 2px 20px rgba(0,0,0,.08), 0 0 0 1px rgba(0,0,0,.04);
    }

    .c1-banner-label {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(.6rem, 1.4vw, .7rem);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--ink-soft);
      margin-bottom: 8px;
    }

    .c1-banner-price {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.8rem, 5vw, 2.4rem);
      font-weight: 700;
      line-height: 1.1;
      color: var(--ink);
    }

    .c1-banner-old {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(.8rem, 1.8vw, .95rem);
      font-weight: 400;
      text-decoration: line-through;
      color: var(--ink-faint);
      display: block;
      margin-bottom: 2px;
    }

    .c1-banner-save {
      display: inline-block;
      margin-top: 10px;
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(.6rem, 1.4vw, .7rem);
      font-weight: 500;
      background: #f0f0f0;
      color: var(--ink);
      padding: 4px 12px;
      border-radius: 100px;
    }

    .c1-banner-deadline {
      font-size: clamp(.6rem, 1.3vw, .68rem);
      color: var(--ink-faint);
      margin-top: 8px;
    }

    .c1-banner-wa {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 14px;
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(.72rem, 1.6vw, .82rem);
      font-weight: 500;
      color: #fff;
      background: #25D366;
      padding: 8px 16px;
      border-radius: 100px;
      text-decoration: none;
      transition: opacity .2s;
    }

    .c1-banner-wa:hover {
      opacity: .85;
    }

    .c1-banner-wa svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    @media (min-width: 768px) {
      .c1-banner {
        bottom: clamp(80px, 10vw, 140px);
        right: clamp(40px, 8vw, 120px);
        max-width: 340px;
      }
    }

    /* ── Burger menu — fixed, always visible ── */
    .burger {
      position: fixed;
      top: clamp(16px, 4vw, 32px);
      right: clamp(16px, 4vw, 32px);
      z-index: 100;
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      padding: 0;
    }

    .burger-line {
      display: block;
      width: 28px;
      height: 3px;
      background: var(--ink);
      border-radius: 2px;
      transition: transform .3s ease, opacity .3s ease;
    }

    /* ── Menu Overlay ── */
    .menu-overlay {
      position: fixed;
      inset: 0;
      z-index: 99;
      background: var(--page-bg);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 32px;
      opacity: 0;
      pointer-events: none;
      transition: opacity .3s ease;
    }

    .menu-overlay.open {
      opacity: 1;
      pointer-events: auto;
    }

    .menu-overlay nav {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
    }

    .menu-link {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 600;
      color: var(--ink);
      text-decoration: none;
      letter-spacing: -.02em;
      transition: opacity .2s ease;
    }

    .menu-link:hover {
      opacity: .5;
    }

    .menu-legal {
      display: flex;
      gap: 16px;
    }

    .menu-legal a {
      font-size: .8rem;
      font-weight: 500;
      color: var(--ink-faint);
      text-decoration: none;
      letter-spacing: .04em;
    }

    .menu-legal a:hover {
      color: var(--ink);
    }

    /* Burger → X transform */
    .burger.is-open .burger-line {
      background: var(--ink);
    }

    .burger.is-open .burger-line::before,
    .burger.is-open .burger-line::after {
      content: '';
      position: absolute;
      width: 28px;
      height: 3px;
      background: var(--ink);
      border-radius: 2px;
    }

    .burger.is-open .burger-line {
      background: transparent;
    }

    .burger.is-open .burger-line::before {
      transform: rotate(45deg);
    }

    .burger.is-open .burger-line::after {
      transform: rotate(-45deg);
    }

    .burger .burger-line {
      position: relative;
    }

    .card-hero-copy {
      position: absolute;
      top: clamp(80px, 18vw, 140px);
      left: clamp(20px, 5vw, 48px);
      text-align: left;
      max-width: 70%;
    }

    .card-hero-headline {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -.02em;
      color: var(--ink);
      margin-bottom: 6px;
    }

    .rwth-link {
      font-size: .65em;
      vertical-align: super;
      text-decoration: underline;
      color: var(--ink-soft);
      margin-left: 1px;
    }

    .photo-gap {
      display: inline-block;
      width: clamp(3rem, 10vw, 8rem);
    }

    .card-hero-sub {
      font-size: clamp(.85rem, 2vw, 1rem);
      color: var(--ink-soft);
      line-height: 1.5;
      text-align: center;
      margin-top: -12px;
      position: relative;
      z-index: 3;
    }

    .card-hero-facts {
      font-size: clamp(.7rem, 1.6vw, .8rem);
      font-weight: 500;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--ink-faint);
      line-height: 1.4;
    }

    .card-number {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(60px, 10vw, 100px);
      font-weight: 700;
      position: absolute;
      right: clamp(16px, 4vw, 60px);
      bottom: clamp(16px, 4vw, 40px);
      line-height: 1;
      color: var(--line);
      opacity: 0.3;
      pointer-events: none;
    }

    /* ── Card 2: Fullscreen video ── */
    .card-video {
      background: #000;
    }

    .card-bg-video {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }


    .card-video-dark::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,.45);
      z-index: 1;
    }

    .video-text-full {
      position: absolute;
      inset: 0;
      z-index: 2;
      display: grid;
      grid-template-rows: minmax(0, 38%) 1fr minmax(0, 30%);
      padding: clamp(16px, 3dvh, 40px) clamp(20px, 5vw, 48px);
    }

    .video-zone-top {
      align-self: end;
      overflow: hidden;
      position: relative;
      padding: clamp(10px, 2dvh, 20px);
      display: flex;
      flex-direction: column;
      gap: clamp(4px, 1dvh, 10px);
    }

    @media (min-width: 768px) {
      .video-zone-top {
        align-self: start;
      }
    }

    .video-zone-top::before {
      content: '';
      position: absolute;
      inset: -4px;
      background: linear-gradient(180deg, rgba(255,255,255,.35) 0%, transparent 100%);
      border-radius: 6px;
      z-index: -1;
      pointer-events: none;
    }

    .video-zone-top .card-title-c2 {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.3rem, 4dvh, 2.6rem);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -.02em;
      color: var(--ink);
      text-align: left;
    }

    .video-zone-top .card-text {
      font-size: clamp(0.82rem, 2.2dvh, 1.1rem);
      line-height: 1.5;
    }

    .video-zone-bottom {
      align-self: end;
      overflow: hidden;
      position: relative;
      padding: clamp(10px, 2dvh, 20px);
      display: flex;
      flex-direction: column;
      gap: clamp(4px, 1dvh, 8px);
    }

    .video-zone-bottom::before {
      content: '';
      position: absolute;
      inset: -4px;
      background: linear-gradient(0deg, rgba(0,0,0,.45) 0%, transparent 100%);
      border-radius: 6px;
      z-index: -1;
      pointer-events: none;
    }

    .video-zone-bottom .card-text {
      font-size: clamp(0.82rem, 2.1dvh, 1.05rem);
      line-height: 1.5;
      color: #FFFFFF;
      font-style: italic;
      text-align: left;
    }



    /* ── Card 4: Math Learnings ── */
    .card-scroll {
      overflow: hidden;
      padding: 0;
      gap: 0;
      flex-direction: column;
    }

    .c4-content {
      padding: 0 clamp(24px, 5vw, 40px);
      text-align: left;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 8px;
      flex: 1;
      min-height: 0;
    }

    @media (min-width: 768px) {
      .c4-content {
        padding: clamp(24px, 5vw, 40px) clamp(24px, 5vw, 40px) 0;
        flex: none;
      }
    }

    .c4-title {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -.02em;
      color: var(--ink);
    }

    .c4-sub {
      font-size: clamp(.88rem, 2vw, 1.1rem);
      color: var(--ink-soft);
      line-height: 1.55;
    }

    .c4-graphic {
      flex: 1;
      min-height: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: clamp(16px, 3vw, 32px);
      overflow: hidden;
    }

    .c4-graphic img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .c4-source {
      font-size: .6rem;
      color: var(--ink-faint);
      opacity: .6;
      text-align: center;
      padding: 0 clamp(16px, 3vw, 32px) 8px;
      line-height: 1.4;
    }

    @media (min-width: 768px) {
      .c4-title {
        font-size: clamp(1.6rem, 3vw, 2.4rem);
      }
      .c4-sub {
        font-size: clamp(.95rem, 1.5vw, 1.15rem);
      }
    }

    /* ── Card 3: Who We Are ── */
    .card-whoweare {
      background: #FFFFFF;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .c3-robot {
      position: absolute;
      bottom: -5%;
      left: -5%;
      width: 25%;
      max-width: 132px;
      object-fit: contain;
      pointer-events: none;
      opacity: .12;
      z-index: 0;
    }

    .c3-photo {
      width: 100%;
      height: 45%;
      object-fit: cover;
      flex-shrink: 0;
    }

    .c3-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(16px, 4vw, 32px) clamp(20px, 5vw, 48px);
      gap: 8px;
      text-align: left;
    }

    .c3-title {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -.02em;
      color: var(--ink);
    }

    .c3-sub {
      font-size: clamp(.85rem, 2vw, 1.1rem);
      color: var(--ink-soft);
      line-height: 1.55;
    }

    .c3-team {
      display: flex;
      justify-content: center;
      gap: clamp(16px, 3vw, 32px);
      margin-top: 8px;
    }

    .c3-member {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
      flex: 1;
    }

    .c3-name {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(.9rem, 2vw, 1.15rem);
      font-weight: 600;
      color: var(--ink);
    }

    .c3-role {
      font-size: clamp(.75rem, 1.5vw, .95rem);
      color: var(--ink-soft);
    }

    .c3-degree {
      font-size: clamp(.7rem, 1.3vw, .88rem);
      color: var(--ink-faint);
      letter-spacing: .04em;
    }

    .c3-degree-sub {
      font-size: clamp(.65rem, 1.2vw, .82rem);
      color: var(--ink-faint);
      letter-spacing: .04em;
      padding-left: 12px;
      position: relative;
    }

    .c3-degree-sub::before {
      content: '·';
      position: absolute;
      left: 2px;
      font-weight: 700;
    }

    .c3-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: 4px;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: .75rem;
      font-weight: 600;
      letter-spacing: .03em;
      border: 1px solid var(--line);
      color: var(--ink-soft);
      background: var(--page-bg);
      width: fit-content;
    }
    .c3-badge svg { flex-shrink: 0; }

    .c3-motto {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(.85rem, 1.8vw, 1.05rem);
      font-style: italic;
      color: var(--ink);
      margin-top: 8px;
    }

    @media (min-width: 768px) {
      .card-whoweare {
        flex-direction: row;
      }
      .c3-photo {
        width: 40%;
        height: 100%;
        flex-shrink: 0;
      }
      .c3-content {
        padding: clamp(24px, 3vw, 48px);
        gap: 14px;
      }
      .c3-title {
        font-size: clamp(1.6rem, 3vw, 2.4rem);
      }
      .c3-sub {
        font-size: clamp(.95rem, 1.5vw, 1.15rem);
      }
      .c3-name {
        font-size: clamp(1rem, 1.5vw, 1.2rem);
      }
      .c3-role {
        font-size: clamp(.85rem, 1.2vw, 1rem);
      }
      .c3-degree {
        font-size: clamp(.8rem, 1.1vw, .92rem);
      }
      .c3-degree-sub {
        font-size: clamp(.75rem, 1vw, .88rem);
      }
      .c3-badge {
        font-size: .8rem;
      }
    }

    /* ── Card 5: Booking ── */
    .card-booking {
      gap: 16px;
      justify-content: center;
      background: #FFFFFF;
    }

    .booking-eyebrow {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .32em;
      color: rgba(255,255,255,.8);
    }

    .booking-title {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(2rem, 6vw, 3.4rem);
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -.02em;
      color: #FFFFFF;
    }

    .booking-details {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-top: 4px;
    }

    .booking-detail {
      font-size: clamp(.78rem, 1.8vw, .9rem);
      font-weight: 500;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: rgba(255,255,255,.7);
      line-height: 1.4;
    }

    .booking-price {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(2.4rem, 7vw, 4rem);
      font-weight: 700;
      color: #FFFFFF;
      line-height: 1;
      margin-top: 8px;
