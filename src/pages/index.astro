<script>
  // Shrink-to-fit: reduce font-size until text fits in zone
  function shrinkToFit() {
    document.querySelectorAll('[data-shrink]').forEach(function(zone) {
      var els = zone.querySelectorAll('.card-text, .card-title-c2');
      // Reset first
      els.forEach(function(el) { el.style.fontSize = ''; });
      // Only shrink on mobile (<768px)
      if (window.innerWidth >= 768) return;
      // Shrink if overflowing
      var tries = 0;
      while (zone.scrollHeight > zone.clientHeight + 1 && tries < 20) {
        els.forEach(function(el) {
          var current = parseFloat(getComputedStyle(el).fontSize);
          if (current > 12) {
            el.style.fontSize = (current - 0.5) + 'px';
          }
        });
        tries++;
      }
    });
  }
  window.addEventListener('load', shrinkToFit);
  window.addEventListener('resize', shrinkToFit);
</script>
