  description="German-engineered AI and robotics education for kids aged 6-14. Hong Kong Island & online worldwide."
  extraFonts={['Noto+Sans+TC:wght@400;500;700']}
>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-bg-orb"></div>
  <div class="hero-bg-orb"></div>
  <div class="hero-bg-orb"></div>
  <div class="hero-grid"></div>

  <div class="hero-content">
    <div class="hero-badge" data-lang-en>
      Hong Kong Island &middot; Ages 6&ndash;14 &middot; English &amp; German
    </div>
    <div class="hero-badge" data-lang-de>
      Hong Kong Island &middot; Alter 6&ndash;14 &middot; Englisch &amp; Deutsch
    </div>

    <h1 data-lang-en>Where <span class="gradient-text">Robotics<br />meets AI.</span></h1>
    <h1 data-lang-de>Wo <span class="gradient-text">Robotik<br />auf KI trifft.</span></h1>

    <p class="hero-sub" data-lang-en>Build it. Understand it. Unforgettable experiences with friends &amp; family &mdash; while learning the basics of robotics and AI. Physical classes &amp; online worldwide.</p>
    <p class="hero-sub" data-lang-de>Baue es. Verstehe es. Unvergessliche Erlebnisse mit Freunden &amp; Familie &mdash; und dabei die Grundlagen von Robotik und KI lernen. Pr&auml;senzunterricht &amp; online weltweit.</p>

