  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --sweep-wall: #F3F1ED;
      --sweep-floor: #E1DCD4;
      --horizon: #ECE8E1;
      --ink: #181310;
      --ink-soft: #7A736A;
      --ink-faint: #B7AFA4;
      --line: #D6D0C6;
      --page-bg: #FBFAF8;
    }

    /* Body doesn't scroll → no pull-to-refresh */
    html, body {
      height: 100%;
      overflow: hidden;
    }

    body {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      background: #FFFFFF;
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
    }

    /* All scrolling happens here */
    .scroll-root {
      height: 100dvh;
      overflow-y: auto;
      overscroll-behavior-y: none;
      -webkit-overflow-scrolling: touch;
    }

    /* ── Card wrappers ── */
    .card-wrap {
      height: 200dvh;
    }

    .card-wrap:first-child {
      height: 100dvh;
    }

    /* Last card keeps 200dvh default — margin eats 100dvh,
       remaining 100dvh ensures card is reachable */

    .card-wrap + .card-wrap {
      margin-top: -100dvh;
    }

    /* Descending z-index: Card 1 on top, peels to reveal Card 2, etc. */
    .card-wrap:nth-child(1) .card { z-index: 5; }
    .card-wrap:nth-child(2) .card { z-index: 4; }
    .card-wrap:nth-child(3) .card { z-index: 3; }
    .card-wrap:nth-child(4) .card { z-index: 2; }
    .card-wrap:nth-child(5) .card { z-index: 1; }

    /* ── Card ── */
    .card {
      position: sticky;
      top: 0;
      height: 100dvh;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 6vh 24px;
      gap: 22px;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
      overflow: hidden;
    }

    .card-label {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .32em;
      color: var(--ink-soft);
    }

    .card-title {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(2.6rem, 8vw, 5.2rem);
      font-weight: 600;
      line-height: .98;
      letter-spacing: -.02em;
      color: var(--ink);
      max-width: 14ch;
    }

    .card-hero-title {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-weight: 900;
      text-transform: uppercase;
      white-space: nowrap;
      font-size: 5.8vw;
      line-height: 1;
      letter-spacing: .32em;
      color: var(--ink);
      border: 2px solid var(--ink);
      padding: .4em .5em;
    }

    .card-text {
      max-width: 38ch;
      color: var(--ink-soft);
      font-size: clamp(1rem, 2.4vw, 1.15rem);
      line-height: 1.55;
    }

    .card-hero-img {
      position: absolute;
      left: -5%;
      bottom: -5%;
      height: 55%;
      width: auto;
      pointer-events: none;
      transform: translateX(-110%);
    }

    .card-hero-img.animate {
      animation: slideInLeft 1.2s cubic-bezier(.22, 1, .36, 1) forwards;
    }

    @keyframes slideInLeft {
      to { transform: translateX(0); }
    }

    /* ── Burger menu — fixed, always visible ── */
    .burger {
      position: fixed;
      top: clamp(16px, 4vw, 32px);
      right: clamp(16px, 4vw, 32px);
      z-index: 100;
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      padding: 0;
    }

    .burger-line {
      display: block;
      width: 28px;
      height: 3px;
      background: var(--ink);
      border-radius: 2px;
      transition: transform .3s ease, opacity .3s ease;
    }

    /* ── Menu Overlay ── */
    .menu-overlay {
      position: fixed;
      inset: 0;
      z-index: 99;
      background: var(--page-bg);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 32px;
      opacity: 0;
      pointer-events: none;
      transition: opacity .3s ease;
    }

    .menu-overlay.open {
      opacity: 1;
      pointer-events: auto;
    }

    .menu-overlay nav {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
    }

    .menu-link {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 600;
      color: var(--ink);
      text-decoration: none;
      letter-spacing: -.02em;
      transition: opacity .2s ease;
    }

    .menu-link:hover {
      opacity: .5;
    }

    .menu-legal {
      display: flex;
      gap: 16px;
    }

    .menu-legal a {
      font-size: .8rem;
      font-weight: 500;
      color: var(--ink-faint);
      text-decoration: none;
      letter-spacing: .04em;
    }

    .menu-legal a:hover {
      color: var(--ink);
    }

    /* Burger → X transform */
    .burger.is-open .burger-line {
      background: var(--ink);
    }

    .burger.is-open .burger-line::before,
    .burger.is-open .burger-line::after {
      content: '';
      position: absolute;
      width: 28px;
      height: 3px;
      background: var(--ink);
      border-radius: 2px;
    }

    .burger.is-open .burger-line {
      background: transparent;
    }

    .burger.is-open .burger-line::before {
      transform: rotate(45deg);
    }

    .burger.is-open .burger-line::after {
      transform: rotate(-45deg);
    }

    .burger .burger-line {
      position: relative;
    }

    .card-hero-copy {
      position: absolute;
      top: clamp(80px, 18vw, 140px);
      left: clamp(20px, 5vw, 48px);
      text-align: left;
      max-width: 70%;
    }

    .card-hero-headline {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -.02em;
      color: var(--ink);
      margin-bottom: 6px;
    }

    .rwth-link {
      font-size: .65em;
      vertical-align: super;
      text-decoration: underline;
      color: var(--ink-soft);
      margin-left: 1px;
    }

    .photo-gap {
      display: inline-block;
      width: clamp(3rem, 10vw, 8rem);
    }

    .card-hero-sub {
      font-size: clamp(.85rem, 2vw, 1rem);
      color: var(--ink-soft);
      line-height: 1.5;
      text-align: center;
      margin-top: -12px;
      position: relative;
      z-index: 3;
    }

    .card-hero-facts {
      font-size: clamp(.7rem, 1.6vw, .8rem);
      font-weight: 500;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--ink-faint);
      line-height: 1.4;
    }

    .card-number {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(60px, 10vw, 100px);
      font-weight: 700;
      position: absolute;
      right: clamp(16px, 4vw, 60px);
      bottom: clamp(16px, 4vw, 40px);
      line-height: 1;
      color: var(--line);
      opacity: 0.3;
      pointer-events: none;
    }

    /* ── Card 2: Fullscreen video ── */
    .card-video {
      background: #000;
    }

    .card-bg-video {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }


    .card-video-dark::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,.45);
      z-index: 1;
    }

    .video-text-full {
      position: absolute;
      top: clamp(20px, 5vw, 48px);
      left: clamp(20px, 5vw, 48px);
      right: clamp(20px, 5vw, 48px);
      bottom: clamp(20px, 5vw, 48px);
      z-index: 2;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .video-story {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }



    /* ── Card 3: AI Learning Unit ── */
    .card-scroll {
      overflow: hidden;
      padding: 0;
      gap: 0;
    }

    .c3-rover-zone {
      flex: 1;
      min-height: 0;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      overflow: hidden;
    }

    .c3-rover-zone img {
      max-width: 85%;
      max-height: 95%;
      object-fit: contain;
      pointer-events: none;
    }

    .c3-promo {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(24px, 5vw, 40px);
      gap: 12px;
      text-align: left;
    }

    .c3-promo-eyebrow {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .25em;
      color: var(--ink-faint);
    }

    .c3-promo-headline {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.3rem, 4vw, 2rem);
      font-weight: 600;
      line-height: 1.15;
      letter-spacing: -.02em;
      color: var(--ink);
    }

    .c3-checklist {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .c3-checklist li {
      font-size: clamp(.88rem, 1.8vw, 1rem);
      color: var(--ink);
      line-height: 1.5;
      padding-left: 24px;
      position: relative;
    }

    .c3-checklist li::before {
      content: '\2713';
      position: absolute;
      left: 0;
      color: var(--ink-faint);
      font-weight: 600;
    }

    .c3-promo-footer {
      font-size: clamp(.82rem, 1.6vw, .92rem);
      color: var(--ink-soft);
      font-style: italic;
      margin-top: 4px;
    }

    @media (min-width: 768px) {
      .card-scroll {
        flex-direction: row;
      }
      .c3-rover-zone, .c3-promo {
        flex: 1;
        height: 100%;
      }
      .c3-promo {
        padding: clamp(32px, 4vw, 60px);
      }
    }

    /* ── Card 4: Who We Are ── */
    .card-whoweare {
      background: #FFFFFF;
      display: flex;
      flex-direction: column;
    }

    .c4-photo {
      width: 100%;
      height: 45%;
      object-fit: cover;
      flex-shrink: 0;
    }

    .c4-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(16px, 4vw, 32px) clamp(20px, 5vw, 48px);
      gap: 8px;
      text-align: left;
    }

    .c4-title {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -.02em;
      color: var(--ink);
    }

    .c4-sub {
      font-size: clamp(.85rem, 2vw, 1rem);
      color: var(--ink-soft);
      line-height: 1.5;
    }

    .c4-team {
      display: flex;
      gap: clamp(16px, 3vw, 32px);
      margin-top: 8px;
    }

    .c4-member {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .c4-name {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(.9rem, 2vw, 1.05rem);
      font-weight: 600;
      color: var(--ink);
    }

    .c4-role {
      font-size: clamp(.75rem, 1.5vw, .85rem);
      color: var(--ink-soft);
    }

    .c4-degree {
      font-size: clamp(.7rem, 1.3vw, .78rem);
      color: var(--ink-faint);
      letter-spacing: .04em;
    }

    .c4-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: 4px;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: .65rem;
      font-weight: 600;
      letter-spacing: .03em;
      border: 1px solid var(--line);
      color: var(--ink-soft);
      background: var(--page-bg);
      width: fit-content;
    }
    .c4-badge svg { flex-shrink: 0; }

    .c4-motto {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(.85rem, 1.8vw, 1rem);
      font-style: italic;
      color: var(--ink);
      margin-top: 8px;
    }

    /* ── Card 5: Booking ── */
    .card-booking {
      gap: 16px;
      justify-content: center;
      background: #FFFFFF;
    }

    .booking-eyebrow {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .32em;
      color: rgba(255,255,255,.8);
    }

    .booking-title {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(2rem, 6vw, 3.4rem);
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -.02em;
      color: #FFFFFF;
    }

    .booking-details {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-top: 4px;
    }

    .booking-detail {
      font-size: clamp(.78rem, 1.8vw, .9rem);
      font-weight: 500;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: rgba(255,255,255,.7);
      line-height: 1.4;
    }

    .booking-price {
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(2.4rem, 7vw, 4rem);
      font-weight: 700;
      color: #FFFFFF;
      line-height: 1;
      margin-top: 8px;
    }

    .booking-price-note {
      font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: .8rem;
      color: rgba(255,255,255,.6);
      margin-top: -4px;
    }

    .booking-cta {
      display: inline-block;
      margin-top: 12px;
      padding: 18px 48px;
      font-family: 'Space Grotesk', ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: clamp(1rem, 2.5vw, 1.15rem);
      font-weight: 600;
      letter-spacing: .04em;
      text-transform: uppercase;
      text-decoration: none;
      color: #FFFFFF;
      background: var(--ink);
      border: none;
      border-radius: 0;
      cursor: pointer;
      transition: background .2s ease, transform .15s ease;
      -webkit-tap-highlight-color: transparent;
    }

    .booking-cta:hover {
      background: #2C2520;
    }

    .booking-cta:active {
      transform: scale(.97);
    }

    .booking-methods {
      display: flex;
      gap: 16px;
      align-items: center;
      margin-top: 4px;
    }

    .mini-footer-inline {
      position: absolute;
      bottom: clamp(8px, 2vw, 16px);
      left: 0;
      right: 0;
      text-align: center;
      font-size: .65rem;
      color: var(--ink-faint);
      z-index: 2;
    }

    .mini-footer-inline a {
      color: var(--ink-faint);
      text-decoration: none;
    }

    .mini-footer-inline a:hover { color: var(--ink); }

    .c5-whatsapp {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 8px;
      font-size: clamp(.8rem, 1.8vw, .9rem);
      font-weight: 500;
      color: #25D366;
      text-decoration: none;
      transition: opacity .2s ease;
    }

    .c5-whatsapp:hover {
      opacity: .7;
    }

    .c5-wa-icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
    }


    .card-booking > *:not(.card-bg-video):not(.card-number) {
      position: relative;
      z-index: 2;
    }
  </style>
</head>
