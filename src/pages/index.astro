      <a href="#reserve" class="btn-primary" data-lang-de>Reservieren &rarr;</a>
      <a href="#programs" class="btn-secondary" data-lang-en>Explore Programs</a>
      <a href="#programs" class="btn-secondary" data-lang-de>Programme entdecken</a>
    </div>
  </div>

  <div class="hero-visual">
    <div class="hero-robot">
      <div class="robot-ring"></div>
      <div class="robot-ring"></div>
      <div class="robot-ring"></div>
