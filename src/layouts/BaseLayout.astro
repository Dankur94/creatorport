---
interface Props {
  title: string;
  description?: string;
  /** Additional fonts beyond Sora (e.g. 'Sacramento', 'Space+Mono') */
  extraFonts?: string[];
}

const {
  title,
  description = 'German-engineered AI and robotics education for kids and institutions. Hong Kong Island & online worldwide.',
  extraFonts = ['Space+Mono:wght@400;700'],
} = Astro.props;

const fontFamilies = ['Sora:wght@300;400;500;600;700;800', ...extraFonts];
const fontUrl = `https://fonts.googleapis.com/css2?${fontFamilies.map(f => `family=${f}`).join('&')}&display=swap`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href={fontUrl} rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/animations.css';
</style>
