---
import PageLayout from '../layouts/PageLayout.astro';

const navLinks = [{ href: '/adults', en: '\u2190 All Workshops', de: '\u2190 Alle Workshops' }];
---

<PageLayout
  title="CreatorPort HK — Build a Beer Tap System"
  description="Build your own automated beer tap system. Group workshop with beer tasting. Coming soon to Hong Kong."
  navLinks={navLinks}
  navCta={{ href: 'https://wa.me/85265427963?text=%23zapfsystem', en: 'Send #zapfsystem', de: '#zapfsystem senden' }}
  navAccent="amber"
>
  <!-- HERO -->
  <div class="hero">
    <div class="coming-soon-badge reveal" data-lang-en>Coming Soon</div>
    <div class="coming-soon-badge reveal" data-lang-de>Demnächst</div>
    <div class="hero-tag reveal" data-lang-en>Workshop #01 &middot; DIY Robotics &middot; Social Experience</div>
    <div class="hero-tag reveal" data-lang-de>Workshop #01 &middot; DIY-Robotik &middot; Soziales Erlebnis</div>
    <h1 class="reveal" data-lang-en>Build a<br><span class="gradient-text">Beer Tap System</span></h1>
    <h1 class="reveal" data-lang-de>Baue ein<br><span class="gradient-text">Bierzapfsystem</span></h1>
    <p class="hero-sub reveal" data-lang-en>A hands-on workshop where you build a real automated beer tap &mdash; and test it with your group over fresh beer.</p>
    <p class="hero-sub reveal" data-lang-de>Ein Hands-on-Workshop, in dem du ein echtes automatisiertes Zapfsystem baust &mdash; und es mit deiner Gruppe bei frischem Bier testest.</p>
  </div>

  <!-- CONTENT -->
  <div class="content">
    <!-- Detail Card 1 -->
    <div class="detail-card reveal">
      <h2 data-lang-en>What you&rsquo;ll build</h2>
      <h2 data-lang-de>Was du baust</h2>
      <ul class="detail-list">
        <li data-lang-en>Automated beer tap system with 4-litre capacity</li>
        <li data-lang-de>Automatisiertes Zapfsystem mit 4-Liter-Kapazit&auml;t</li>
        <li data-lang-en>Temperature sensors for optimal serving temperature</li>
        <li data-lang-de>Temperatursensoren f&uuml;r optimale Ausschanktemperatur</li>
        <li data-lang-en>Flow meters to measure pour volume</li>
        <li data-lang-de>Durchflussmesser zur Messung des Zapfvolumens</li>
        <li data-lang-en>Arduino-controlled solenoid valves</li>
        <li data-lang-de>Arduino-gesteuerte Magnetventile</li>
        <li data-lang-en>Fully functional tap you can use on the day</li>
        <li data-lang-de>Voll funktionsf&auml;higes Zapfsystem, das du am Tag nutzen kannst</li>
      </ul>
    </div>

    <!-- Detail Card 2 -->
    <div class="detail-card reveal">
      <h2 data-lang-en>Workshop details</h2>
      <h2 data-lang-de>Workshop-Details</h2>
      <ul class="detail-list">
        <li data-lang-en>Duration: ~3 hours</li>
        <li data-lang-de>Dauer: ~3 Stunden</li>
        <li data-lang-en>Group size: max 6 people</li>
        <li data-lang-de>Gruppengr&ouml;&szlig;e: max. 6 Personen</li>
        <li data-lang-en>Flexible scheduling &mdash; book a date that works for your group</li>
        <li data-lang-de>Flexible Terminplanung &mdash; buche ein Datum, das f&uuml;r deine Gruppe passt</li>
        <li data-lang-en>Includes beer tasting at the end</li>
        <li data-lang-de>Inklusive Bierverkostung am Ende</li>
        <li data-lang-en>Location: Tsuen Wan, Riviera Gardens</li>
        <li data-lang-de>Ort: Tsuen Wan, Riviera Gardens</li>
      </ul>
    </div>

    <!-- Highlight Box (Coming Soon) -->
    <div class="highlight-box reveal">
      <p data-lang-en>This workshop is currently being finalised.</p>
      <p data-lang-de>Dieser Workshop wird gerade fertiggestellt.</p>
      <p data-lang-en style="font-weight: 400; color: var(--text-secondary); font-size: 14px;">Interested? Send <strong style="color: var(--accent-amber);">#zapfsystem</strong> on WhatsApp and we&rsquo;ll notify you when it&rsquo;s ready.</p>
      <p data-lang-de style="font-weight: 400; color: var(--text-secondary); font-size: 14px;">Interessiert? Sende <strong style="color: var(--accent-amber);">#zapfsystem</strong> per WhatsApp und wir benachrichtigen dich, wenn es soweit ist.</p>
      <a href="https://wa.me/85265427963?text=%23zapfsystem" target="_blank" class="btn-secondary" style="margin-top: 16px; display: inline-block;" data-lang-en>Send #zapfsystem &rarr;</a>
      <a href="https://wa.me/85265427963?text=%23zapfsystem" target="_blank" class="btn-secondary" style="margin-top: 16px; display: inline-block;" data-lang-de>#zapfsystem senden &rarr;</a>
    </div>
  </div>
</PageLayout>

<style is:global>
  @import '../styles/components.css';
</style>

<style>
  .hero {
    min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center; padding: 120px 40px 80px; position: relative;
  }
  .hero-tag { font-size: 14px; text-transform: uppercase; letter-spacing: 3px; font-weight: 600; margin-bottom: 24px; color: var(--accent-amber); }
  .hero h1 { font-size: 64px; font-weight: 800; letter-spacing: -3px; line-height: 1.05; margin-bottom: 24px; max-width: 800px; }
  .hero-sub { font-size: 20px; color: var(--text-secondary); max-width: 600px; line-height: 1.7; margin-bottom: 40px; }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
  .btn-secondary { padding: 16px 36px; border-radius: 30px; font-weight: 600; font-size: 16px; text-decoration: none; color: var(--text-primary); border: 1px solid var(--border-subtle); background: transparent; transition: all 0.3s; }
  .btn-secondary:hover { border-color: var(--accent-amber); color: var(--accent-amber); }
  .content { max-width: 700px; margin: 0 auto; padding: 0 40px 100px; }

  .coming-soon-badge {
    background: rgba(239, 159, 39, 0.08);
    border: 1px dashed rgba(239, 159, 39, 0.4);
    color: var(--accent-amber);
  }

  .detail-card { border: 1px solid rgba(239, 159, 39, 0.15); }
  .detail-list li::before { color: var(--accent-amber); }

  .highlight-box {
    background: rgba(239, 159, 39, 0.06);
    border: 1px dashed rgba(239, 159, 39, 0.3);
  }
  .highlight-box p { color: var(--accent-amber); }

  .lang-btn.active { background: var(--accent-amber); }

  @media (max-width: 768px) {
    .hero { padding: 100px 24px 60px; min-height: auto; }
    .hero h1 { font-size: 36px; letter-spacing: -1.5px; }
    .hero-sub { font-size: 16px; }
    .hero-actions { flex-direction: column; }
    .btn-primary, .btn-secondary { width: 100%; text-align: center; justify-content: center; }
    .content { padding: 0 24px 80px; }
  }
  @media (max-width: 1024px) and (min-width: 769px) {
    .hero h1 { font-size: 52px; }
  }
</style>
