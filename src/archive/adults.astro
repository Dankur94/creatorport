---
import PageLayout from '../layouts/PageLayout.astro';
import DemandCounter from '../components/DemandCounter.astro';

const navLinks = [
  { href: '#workshops', en: 'Workshops', de: 'Workshops' },
  { href: '#how', en: 'How It Works', de: "So funktioniert's" },
  { href: '/our-story', en: 'Our Story', de: 'Unsere Geschichte' },
];

const navCta = {
  href: 'https://wa.me/85265427963?text=Hi%21%20I%27d%20like%20to%20book%20a%20CreatorPort%20HK%20workshop.%0A-%20Name%3A%0A-%20Workshop%3A%0A-%20Number%20of%20participants%3A%0A-%20Preferred%20date%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29',
  en: 'Book Now',
  de: 'Jetzt buchen',
};
---

<PageLayout
  title="CreatorPort HK — Workshops for Adults"
  description="Build robots. Understand AI. German-engineered workshops for curious adults in Hong Kong."
  navCta={navCta}
  navLinks={navLinks}
  footerExtra={'Kits by <a href="https://kurthtechnik.de" target="_blank" style="color: var(--accent-amber);">&copy; KurthTechnik</a>'}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge reveal" data-lang-en>
      <span>Gauging demand &middot; We launch at <strong>20</strong> sign-ups &middot; <strong class="demand-count-en"></strong> to go &middot; Tsuen Wan, Riviera Gardens</span>
    </div>
    <div class="hero-badge reveal" data-lang-de>
      <span>Nachfrage testen &middot; Wir starten ab <strong>20</strong> Anmeldungen &middot; noch <strong class="demand-count-de"></strong> &middot; Tsuen Wan, Riviera Gardens</span>
    </div>
    <DemandCounter signedUp={0} goal={20} />
    <div class="hero-tag reveal" data-lang-en>Workshops for Adults</div>
    <div class="hero-tag reveal" data-lang-de>Workshops f&uuml;r Erwachsene</div>
    <h1 class="reveal" data-lang-en>Build it.<br /><span class="gradient-text">Understand it.</span></h1>
    <h1 class="reveal" data-lang-de>Baue es.<br /><span class="gradient-text">Verstehe es.</span></h1>
    <p class="hero-sub reveal" data-lang-en>Unforgettable experiences with friends &mdash; while learning the basics of robotics and AI.</p>
    <p class="hero-sub reveal" data-lang-de>Unvergessliche Erlebnisse mit Freunden &mdash; und dabei die Grundlagen von Robotik und KI lernen.</p>
  </section>

  <!-- WORKSHOPS -->
  <section id="workshops">
    <div class="section-label reveal" data-lang-en>Workshops &amp; Services</div>
    <div class="section-label reveal" data-lang-de>Workshops &amp; Services</div>
    <h2 class="section-title reveal" data-lang-en>Pick your<br />next adventure.</h2>
    <h2 class="section-title reveal" data-lang-de>W&auml;hle dein<br />n&auml;chstes Abenteuer.</h2>
    <p class="section-desc reveal" data-lang-en>Hands-on sessions. Small groups. Everything provided. Walk in curious, walk out building.</p>
    <p class="section-desc reveal" data-lang-de>Praxis-Sessions. Kleine Gruppen. Alles inklusive. Komm neugierig, geh als Macher.</p>

    <div class="workshops-grid">
      <!-- 01 BEER TAP -->
      <a href="/beertap" class="workshop-link color-amber reveal">
        <div class="ws-icon">&#x1F37A;</div>
        <div class="ws-num">#01</div>
        <div class="ws-title" data-lang-en>Build a Beer Tap</div>
        <div class="ws-title" data-lang-de>Baue ein Zapfsystem</div>
        <div class="ws-meta" data-lang-en>Group experience &middot; Coming Soon</div>
        <div class="ws-meta" data-lang-de>Gruppenerlebnis &middot; In Vorbereitung</div>
        <p class="ws-desc" data-lang-en>Build your own automated beer tap together while tasting different beer styles. DIY robotics meets social fun.</p>
        <p class="ws-desc" data-lang-de>Baut zusammen eure eigene automatische Zapfanlage und probiert dabei verschiedene Biersorten. DIY-Robotik trifft Geselligkeit.</p>
        <span class="ws-arrow" data-lang-en>Learn more &rarr;</span>
        <span class="ws-arrow" data-lang-de>Mehr erfahren &rarr;</span>
        <div class="ws-booking" onclick="event.preventDefault();event.stopPropagation();">
          <span class="ws-booking-btn ws-booking-notify" data-lang-en onclick="window.open('https://wa.me/85265427963?text=Hi%21%20Please%20notify%20me%20when%20%22Build%20a%20Beer%20Tap%22%20opens%20for%20booking.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Get notified once course opens</span>
          <span class="ws-booking-btn ws-booking-notify" data-lang-de onclick="window.open('https://wa.me/85265427963?text=Hallo%21%20Bitte%20benachrichtigt%20mich%2C%20wenn%20%22Baue%20ein%20Zapfsystem%22%20buchbar%20ist.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Benachrichtigen, wenn buchbar</span>
        </div>
      </a>

      <!-- 02 COFFEE ROASTER -->
      <a href="/coffee-roaster" class="workshop-link color-amber reveal">
        <div class="ws-icon">&#x2615;</div>
        <div class="ws-num">#02</div>
        <div class="ws-title" data-lang-en>Build a Coffee Roaster</div>
        <div class="ws-title" data-lang-de>Baue einen Kaffeer&ouml;ster</div>
        <div class="ws-meta" data-lang-en>Group experience &middot; 3h &middot; $600/person</div>
        <div class="ws-meta" data-lang-de>Gruppenerlebnis &middot; 3h &middot; $600/Person</div>
        <p class="ws-desc" data-lang-en>Build your own CloudRoast Mini and taste the difference between roast levels from beans you roasted yourself.</p>
        <p class="ws-desc" data-lang-de>Baue deinen eigenen CloudRoast Mini und schmecke den Unterschied zwischen R&ouml;stgraden aus selbst ger&ouml;steten Bohnen.</p>
        <span class="ws-arrow" data-lang-en>Learn more &rarr;</span>
        <span class="ws-arrow" data-lang-de>Mehr erfahren &rarr;</span>
        <div class="ws-booking" onclick="event.preventDefault();event.stopPropagation();">
          <span class="ws-booking-btn ws-booking-reserve" data-lang-en onclick="window.open('https://wa.me/85265427963?text=Hi%21%20I%27d%20like%20to%20reserve%20a%20spot%20for%20the%20Coffee%20Roaster%20workshop.%0A-%20Name%3A%0A-%20Number%20of%20participants%3A%0A-%20Preferred%20date%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F4B0; Limited spots &mdash; save a spot for $500 HKD</span>
          <span class="ws-booking-btn ws-booking-reserve" data-lang-de onclick="window.open('https://wa.me/85265427963?text=Hallo%21%20Ich%20m%C3%B6chte%20einen%20Platz%20f%C3%BCr%20den%20Kaffeer%C3%B6ster-Workshop%20reservieren.%0A-%20Name%3A%0A-%20Anzahl%20Teilnehmer%3A%0A-%20Wunschdatum%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F4B0; Begrenzte Pl&auml;tze &mdash; Platz sichern f&uuml;r $500 HKD</span>
          <span class="ws-booking-btn ws-booking-wait" data-lang-en onclick="window.open('https://wa.me/85265427963?text=Hi%21%20I%27d%20like%20to%20join%20the%20waiting%20list%20for%20the%20Coffee%20Roaster%20workshop.%0A-%20Name%3A%0A-%20Number%20of%20participants%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F4CB; Join the waiting list</span>
          <span class="ws-booking-btn ws-booking-wait" data-lang-de onclick="window.open('https://wa.me/85265427963?text=Hallo%21%20Ich%20m%C3%B6chte%20mich%20auf%20die%20Warteliste%20f%C3%BCr%20den%20Kaffeer%C3%B6ster-Workshop%20setzen.%0A-%20Name%3A%0A-%20Anzahl%20Teilnehmer%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F4CB; Auf die Warteliste</span>
        </div>
      </a>

      <!-- 03 GRIPPER DRONE -->
      <a href="/drone" class="workshop-link color-electric reveal">
        <div class="ws-icon">&#x1F681;</div>
        <div class="ws-num">#03</div>
        <div class="ws-title" data-lang-en>Build a Gripper Drone</div>
        <div class="ws-title" data-lang-de>Baue eine Greifer-Drohne</div>
        <div class="ws-meta" data-lang-en>Group experience &middot; 4h &middot; $150 USD/person</div>
        <div class="ws-meta" data-lang-de>Gruppenerlebnis &middot; 4h &middot; $150 USD/Person</div>
        <p class="ws-desc" data-lang-en>Assemble a real indoor drone with a mechanical gripper arm. Fly missions, grab objects, compete with your team. You take it home.</p>
        <p class="ws-desc" data-lang-de>Baue eine echte Indoor-Drohne mit mechanischem Greifer. Fliege Missionen, greife Objekte, tritt gegen dein Team an. Du nimmst sie mit.</p>
        <span class="ws-arrow" data-lang-en>Learn more &rarr;</span>
        <span class="ws-arrow" data-lang-de>Mehr erfahren &rarr;</span>
        <div class="ws-booking" onclick="event.preventDefault();event.stopPropagation();">
          <span class="ws-booking-btn ws-booking-notify" data-lang-en onclick="window.open('https://wa.me/85265427963?text=Hi%21%20Please%20notify%20me%20when%20%22Build%20a%20Gripper%20Drone%22%20opens%20for%20booking.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Get notified once course opens</span>
          <span class="ws-booking-btn ws-booking-notify" data-lang-de onclick="window.open('https://wa.me/85265427963?text=Hallo%21%20Bitte%20benachrichtigt%20mich%2C%20wenn%20%22Baue%20eine%20Greifer-Drohne%22%20buchbar%20ist.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Benachrichtigen, wenn buchbar</span>
        </div>
      </a>

      <!-- 04 ORBBOT -->
      <a href="/orbbot-workshop" class="workshop-link color-electric reveal">
        <div class="ws-icon">&#x2299;</div>
        <div class="ws-num">#04</div>
        <div class="ws-title" data-lang-en>Build an OrbBot</div>
        <div class="ws-title" data-lang-de>Baue einen OrbBot</div>
        <div class="ws-meta" data-lang-en>Advanced robotics &middot; Coming Soon</div>
        <div class="ws-meta" data-lang-de>Fortgeschrittene Robotik &middot; In Vorbereitung</div>
        <p class="ws-desc" data-lang-en>Assemble a self-balancing robot that stays upright on a ball. Three-axis control, real engineering. You take it home.</p>
        <p class="ws-desc" data-lang-de>Baue einen selbstbalancierenden Roboter, der auf einer Kugel steht. Drei-Achsen-Steuerung, echtes Engineering. Du nimmst ihn mit.</p>
        <span class="ws-arrow" data-lang-en>Learn more &rarr;</span>
        <span class="ws-arrow" data-lang-de>Mehr erfahren &rarr;</span>
        <div class="ws-booking" onclick="event.preventDefault();event.stopPropagation();">
          <span class="ws-booking-btn ws-booking-notify" data-lang-en onclick="window.open('https://wa.me/85265427963?text=Hi%21%20Please%20notify%20me%20when%20%22Build%20an%20OrbBot%22%20opens%20for%20booking.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Get notified once course opens</span>
          <span class="ws-booking-btn ws-booking-notify" data-lang-de onclick="window.open('https://wa.me/85265427963?text=Hallo%21%20Bitte%20benachrichtigt%20mich%2C%20wenn%20%22Baue%20einen%20OrbBot%22%20buchbar%20ist.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Benachrichtigen, wenn buchbar</span>
        </div>
      </a>

      <!-- 05 BUSINESS AUTOMATION -->
      <a href="https://www.bitsbridge.net" target="_blank" class="workshop-link color-lime reveal">
        <div class="ws-icon">&#x26A1;</div>
        <div class="ws-num">#05</div>
        <div class="ws-title" data-lang-en>Business Automation</div>
        <div class="ws-title" data-lang-de>Business-Automatisierung</div>
        <div class="ws-meta" data-lang-en>Connect your tools &middot; Free consultation</div>
        <div class="ws-meta" data-lang-de>Verbinde deine Tools &middot; Kostenloses Erstgespr&auml;ch</div>
        <p class="ws-desc" data-lang-en>Your data is scattered across apps. We connect chat, payments, sensors, and software into one system.</p>
        <p class="ws-desc" data-lang-de>Deine Daten sind &uuml;ber Apps verstreut. Wir verbinden Chat, Zahlungen, Sensoren und Software in ein System.</p>
        <span class="ws-arrow" data-lang-en>Learn more &rarr;</span>
        <span class="ws-arrow" data-lang-de>Mehr erfahren &rarr;</span>
        <div class="ws-booking" onclick="event.preventDefault();event.stopPropagation();">
          <span class="ws-booking-btn ws-booking-notify" data-lang-en onclick="window.open('https://wa.me/85265427963?text=Hi%21%20Please%20notify%20me%20when%20%22Business%20Automation%22%20opens%20for%20booking.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Get notified once course opens</span>
          <span class="ws-booking-btn ws-booking-notify" data-lang-de onclick="window.open('https://wa.me/85265427963?text=Hallo%21%20Bitte%20benachrichtigt%20mich%2C%20wenn%20%22Business-Automatisierung%22%20buchbar%20ist.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Benachrichtigen, wenn buchbar</span>
        </div>
      </a>

      <!-- 06 PRESENTING -->
      <a href="https://theartofpresentation.de/" target="_blank" class="workshop-link color-magenta reveal">
        <div class="ws-icon">&#x1F3A4;</div>
        <div class="ws-num">#06</div>
        <div class="ws-title" data-lang-en>The Art of Presenting</div>
        <div class="ws-title" data-lang-de>Die Kunst des Pr&auml;sentierens</div>
        <div class="ws-meta" data-lang-en>1-on-1 online coaching &middot; by Ananya Singh</div>
        <div class="ws-meta" data-lang-de>1-on-1 Online-Coaching &middot; von Ananya Singh</div>
        <p class="ws-desc" data-lang-en>Master storytelling, slide design, and stage presence. Private coaching by an award-winning educator.</p>
        <p class="ws-desc" data-lang-de>Meistere Storytelling, Foliendesign und B&uuml;hnenpr&auml;senz. Privates Coaching von einer preisgekr&ouml;nten P&auml;dagogin.</p>
        <span class="ws-arrow" data-lang-en>Learn more &rarr;</span>
        <span class="ws-arrow" data-lang-de>Mehr erfahren &rarr;</span>
        <div class="ws-booking" onclick="event.preventDefault();event.stopPropagation();">
          <span class="ws-booking-btn ws-booking-notify" data-lang-en onclick="window.open('https://wa.me/85265427963?text=Hi%21%20Please%20notify%20me%20when%20%22The%20Art%20of%20Presenting%22%20opens%20for%20booking.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Get notified once course opens</span>
          <span class="ws-booking-btn ws-booking-notify" data-lang-de onclick="window.open('https://wa.me/85265427963?text=Hallo%21%20Bitte%20benachrichtigt%20mich%2C%20wenn%20%22Die%20Kunst%20des%20Pr%C3%A4sentierens%22%20buchbar%20ist.%0A-%20Name%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29','_blank')">&#x1F514; Benachrichtigen, wenn buchbar</span>
        </div>
      </a>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" style="background: rgba(44,44,42,0.01);">
    <div class="section-label reveal" data-lang-en>How It Works</div>
    <div class="section-label reveal" data-lang-de>So funktioniert's</div>
    <h2 class="section-title reveal" data-lang-en>Show up. Build. Leave smarter.</h2>
    <h2 class="section-title reveal" data-lang-de>Komm vorbei. Baue. Geh schlauer.</h2>
    <p class="section-desc reveal" data-lang-en>No homework. No commitments. Just a great experience.</p>
    <p class="section-desc reveal" data-lang-de>Keine Hausaufgaben. Keine Verpflichtungen. Einfach ein tolles Erlebnis.</p>

    <div class="steps">
      <div class="step reveal">
        <div class="step-num">01</div>
        <h3 class="step-title" data-lang-en>Pick a Workshop</h3>
        <h3 class="step-title" data-lang-de>Workshop w&auml;hlen</h3>
        <p class="step-desc" data-lang-en>Choose what sparks your interest. Book via WhatsApp in 30 seconds.</p>
        <p class="step-desc" data-lang-de>W&auml;hle, was dich interessiert. Buche per WhatsApp in 30 Sekunden.</p>
      </div>
      <div class="step reveal">
        <div class="step-num">02</div>
        <h3 class="step-title" data-lang-en>Show Up</h3>
        <h3 class="step-title" data-lang-de>Komm vorbei</h3>
        <p class="step-desc" data-lang-en>Tsuen Wan, Riviera Gardens. Everything is set up and waiting for you.</p>
        <p class="step-desc" data-lang-de>Tsuen Wan, Riviera Gardens. Alles ist vorbereitet und wartet auf dich.</p>
      </div>
      <div class="step reveal">
        <div class="step-num">03</div>
        <h3 class="step-title" data-lang-en>Build Something Real</h3>
        <h3 class="step-title" data-lang-de>Baue etwas Echtes</h3>
        <p class="step-desc" data-lang-en>3&ndash;4 hours of hands-on making. Small group. Expert guidance. No lectures.</p>
        <p class="step-desc" data-lang-de>3&ndash;4 Stunden praktisches Arbeiten. Kleine Gruppe. Fachkundige Anleitung. Keine Vortr&auml;ge.</p>
      </div>
      <div class="step reveal">
        <div class="step-num">04</div>
        <h3 class="step-title" data-lang-en>Take It Home</h3>
        <h3 class="step-title" data-lang-de>Nimm es mit</h3>
        <p class="step-desc" data-lang-en>Your robot, your knowledge, your experience. Plus new friends who solder.</p>
        <p class="step-desc" data-lang-de>Dein Roboter, dein Wissen, deine Erfahrung. Plus neue Freunde, die l&ouml;ten.</p>
      </div>
    </div>
  </section>

  <!-- KIDS LINK -->
  <section>
    <div class="about-banner reveal">
      <h3 data-lang-en>Looking for kids programs?</h3>
      <h3 data-lang-de>Kinderprogramme gesucht?</h3>
      <p data-lang-en>We also run term-based AI and robotics programs for ages 9&ndash;15. German-engineered curriculum, small groups, Explorer and Builder levels.</p>
      <p data-lang-de>Wir bieten auch semesterbasierte KI- und Robotik-Programme f&uuml;r 9- bis 15-J&auml;hrige an. German-engineered Lehrplan, kleine Gruppen, Explorer- und Builder-Level.</p>
      <a href="/juniors" data-lang-en>Explore Kids Programs &rarr;</a>
      <a href="/juniors" data-lang-de>Kinderprogramme entdecken &rarr;</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" style="background: linear-gradient(180deg, transparent, rgba(239,159,39,0.03));">
    <h2 class="cta-title reveal" data-lang-en>Stop scrolling.<br /><span class="gradient-text">Start building.</span></h2>
    <h2 class="cta-title reveal" data-lang-de>H&ouml;r auf zu scrollen.<br /><span class="gradient-text">Fang an zu bauen.</span></h2>
    <p class="cta-desc reveal" data-lang-en>Limited spots per session. Book via WhatsApp.</p>
    <p class="cta-desc reveal" data-lang-de>Begrenzte Pl&auml;tze pro Session. Buche per WhatsApp.</p>
    <div class="reveal">
      <a href="https://wa.me/85265427963?text=Hi%21%20I%27d%20like%20to%20book%20a%20CreatorPort%20HK%20workshop.%0A-%20Name%3A%0A-%20Workshop%3A%0A-%20Number%20of%20participants%3A%0A-%20Preferred%20date%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29" target="_blank" class="btn-primary" data-lang-en>Book via WhatsApp</a>
      <a href="https://wa.me/85265427963?text=Hallo%21%20Ich%20m%C3%B6chte%20einen%20CreatorPort%20HK%20Workshop%20buchen.%0A-%20Name%3A%0A-%20Workshop%3A%0A-%20Anzahl%20Teilnehmer%3A%0A-%20Wunschdatum%3A%0A%0ACreatorPort%20HK%20%28%C2%A9%20Space%20of%20Possibilities%20Limited%29" target="_blank" class="btn-primary" data-lang-de>Per WhatsApp buchen</a>
    </div>
  </section>
</PageLayout>

<style is:global>
  @import '../styles/components.css';
</style>

<style>
  .hero {
    min-height: 70vh;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center;
    padding: 120px 40px 60px;
    position: relative;
  }

  .hero-tag {
    font-size: 14px; text-transform: uppercase; letter-spacing: 3px;
    color: var(--accent-amber); font-weight: 600; margin-bottom: 24px;
  }

  .hero h1 {
    font-size: 64px; font-weight: 800; letter-spacing: -3px; line-height: 1.05;
    margin-bottom: 24px; max-width: 800px;
  }

  .hero-sub {
    font-size: 20px; color: var(--text-secondary); max-width: 600px;
    line-height: 1.7; margin-bottom: 40px;
  }

  section { padding: 100px 40px; }

  .section-label { color: var(--accent-amber); text-align: center; }

  .nav-links a { text-transform: uppercase; }

  @media (max-width: 768px) {
    .hero { padding: 100px 24px 40px; min-height: auto; }
    .hero h1 { font-size: 36px; letter-spacing: -1.5px; }
    .hero-sub { font-size: 16px; }
    section { padding: 80px 24px; }
  }

  @media (max-width: 1024px) and (min-width: 769px) {
    .hero h1 { font-size: 52px; }
  }
</style>
